-- ==================== SERVICES ====================
local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService       = game:GetService("HttpService")
local TeleportService   = game:GetService("TeleportService")
local GuiService        = game:GetService("GuiService")

if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Anti-AFK
task.spawn(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/hassanxzayn-lua/Anti-afk/main/antiafkbyhassanxzyn"))()
end)

local player    = Players.LocalPlayer
local PlayerGui = player:WaitForChild("PlayerGui")

-- ==================== STATE FLAGS (declared FIRST) ====================
-- These MUST exist before any function that references them as upvalues.
local hasLeft         = false   -- true once we intentionally enter "leaving" state
local readyToRejoin   = false   -- true when WS says Check=true & Busy=false
local sentFail        = false
local sentRecovered   = false
local ws              = nil
local wsConnected     = false
local watchdogConnection = nil

-- ==================== AUTO-REJOIN GUI ====================
if game.CoreGui:FindFirstChild('AutoRejoin') then
    game.CoreGui.AutoRejoin:Destroy()
end

local AutoRejoin = Instance.new("ScreenGui")
AutoRejoin.Name             = "AutoRejoin"
AutoRejoin.Parent           = game.CoreGui
AutoRejoin.ZIndexBehavior   = Enum.ZIndexBehavior.Sibling
AutoRejoin.ResetOnSpawn     = false

-- ==================== AUTO-REJOIN (unexpected kicks only) ====================
local function setupAutoRejoin()
    GuiService.ErrorMessageChanged:Connect(function()
        -- Only rejoin if we did NOT intentionally leave.
        -- hasLeft is a captured upvalue, so this reads the live value.
        if not hasLeft then
            print("[AUTO-REJOIN] Unexpected disconnect! Rejoining...")
            task.wait(1)
            TeleportService:Teleport(game.PlaceId, player)
        else
            print("[AUTO-REJOIN] Intentional leave in progress, ignoring error.")
        end
    end)
end

-- ==================== WAIT FOR GAME LOAD ====================
local loadingGui = PlayerGui:FindFirstChild("LoadingGui")
if loadingGui then
    print("[INFO] Waiting for LoadingGui to disappear...")
    loadingGui:GetPropertyChangedSignal("Parent"):Wait()
    while loadingGui.Parent do task.wait(0.05) end
    print("[INFO] Loading GUI gone → verifying 5s stable")
    task.wait(5)
end

