-- ==================== GUI PATH ====================
local guiPath = PlayerGui:WaitForChild("Lobby")
    :WaitForChild("PostOffice")
    :WaitForChild("Menus")
    :WaitForChild("ReceivePackages")
    :WaitForChild("ScrollingFrame")

-- ==================== NETWORKING ====================
local remote = ReplicatedStorage:WaitForChild("NetworkingContainer"):WaitForChild("DataRemote")
local idValue = ReplicatedStorage:WaitForChild("IdentifiersContainer"):WaitForChild(
    "RF_59fb8da4c771fdd9e7348c3e113b4939ec60069b536a2ff0e2dd4f9e857a6611_S"
).Value
local staticString = "\218\239*\223\237\226@\151\148Y@7%\190&\159"

-- ==================== LEAVE & WAIT FOR NEXT CYCLE ====================
local function leaveAndWaitForNextCycle()
    print("[LEAVE] Account: " .. player.Name)

    -- Signal dupe to server (all 4 accounts do this once)
    sendDupeTrue()
    print("[LEAVE] Sent Dupe=true")

    task.wait(0.5)

    -- Mark intentional leave. DO NOT Kick — kicking stops the script
    -- and the watchdog would never fire the teleport.
    hasLeft = true
    print("[LEAVE] hasLeft=true. Staying in-game, waiting for WS go-ahead...")

    -- Watchdog: also listen directly for the go-ahead state
    task.spawn(function()
        print("[WATCHDOG] Waiting for Check=true AND Busy=false...")
        if ws and ws.OnMessage then
            watchdogConnection = ws.OnMessage:Connect(function(msg)
                local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
                if ok and data and data.type == "state" and data.state then
                    local check = data.state.Check
                    local busy  = data.state.Busy
                    print(string.format("[WATCHDOG] Check: %s, Busy: %s",
                        tostring(check), tostring(busy)))
                    if check == true and busy == false then
                        readyToRejoin = true
                        if watchdogConnection then
                            watchdogConnection:Disconnect()
                            watchdogConnection = nil
                        end
                    end
                end
            end)
        end

        -- Wait indefinitely for the go-ahead
        while not readyToRejoin do task.wait(0.5) end

        task.wait(1)
        print("[WATCHDOG] Go-ahead received. Teleporting back to game...")
        -- Reset so an unexpected kick during teleport still re-joins.
        hasLeft = false
        TeleportService:Teleport(game.PlaceId, player)
    end)
end

-- ==================== MAIN LOOP ====================
print("[MAIN] Starting main loop - Account: " .. player.Name)

while task.wait() do
    local leaderstats = player:FindFirstChild("leaderstats")
    local gemsObj     = leaderstats and leaderstats:FindFirstChild("Gems")
    local gems        = gemsObj and gemsObj.Value or 0

    -- SUCCESS: reached target gems
    if gems == 2500000 then
        if not sentRecovered and not hasLeft then
            print(string.format("[MAIN] Gems = %d - RECOVERED! Sending Recovered...", gems))
            sentRecovered = true
            pcall(function() sendRecovered(player.Name) end)
            task.wait(0.5)
            print("[MAIN] Sending Dupe=true and leaving cycle...")
            leaveAndWaitForNextCycle()
            -- Stop main loop; watchdog will teleport when ready.
            break
        end
    end

    -- FAIL: no frames after 20s
    if not sentFail then
        local frameFound = false
        local elapsed    = 0
        while elapsed < 20 do
            for _, child in ipairs(guiPath:GetChildren()) do
                if child:IsA("Frame") then
                    frameFound = true
                    break
                end
            end
            if frameFound then break end
            task.wait(0.5)
            elapsed = elapsed + 0.5
        end

        local currentGems = 0
        local ls = player:FindFirstChild("leaderstats")
        if ls then
            local g = ls:FindFirstChild("Gems")
            if g then currentGems = g.Value end
        end

        if currentGems == 2500000 then
            print("[INFO] Already at 2.5M, not reporting failure")
        elseif not frameFound then
            sentFail = true
            print("[INFO] No frames found after 20s - reporting failure")
            pcall(function() sendLose(player.Name) end)
        else
            print("[INFO] Frames found, skipping fail report")
        end
    end

    -- REMOTE FIRING
    for _, child in ipairs(guiPath:GetChildren()) do
        if child:IsA("Frame") then
            local args = { { { idValue, staticString, child.Name } } }
            remote:FireServer(unpack(args))
        end
    end
end
