-- WebSocket Configuration
local WS_URL = "ws://192.168.1.14:8080"
local ws = nil
local wsConnected = false

-- Prevent duplicate requests
local sentFail = false
local sentRecovered = false
local hasLeft = false
local readyToRejoin = false
local watchdogConnection = nil

-- ==================== WEBSOCKET SETUP ====================
local function setupWebSocket()
    local success, result = pcall(function()
        return WebSocket.connect(WS_URL)
    end)

    if success and result then
        ws = result
        wsConnected = true
        print("[WS] Connected to server")

        -- Send client_ready immediately
        ws:Send(HttpService:JSONEncode({ type = "client_ready" }))

        ws.OnMessage:Connect(function(msg)
            print("[WS] Received:", msg)

            local success, data = pcall(function()
                return HttpService:JSONDecode(msg)
            end)

            if success and data then
                -- Handle state messages (server sends { type="state", state={...} })
                if data.type == "state" and data.state then
                    local state = data.state
                    local dupe = state.Dupe
                    local check = state.Check
                    local busy = state.Busy
                    local waitingOn = state.waitingOn
                    
                    print(string.format("[WS] State - Dupe: %s, Check: %s, Busy: %s, Waiting: %s", 
                        tostring(dupe), tostring(check), tostring(busy), tostring(waitingOn)))
                    
                    -- AFTER leaving: wait for Busy=false AND Check=false
                    if hasLeft and not readyToRejoin then
                        if busy == false and check == false then
                            print("[WS] Busy=false & Check=false - Ready to rejoin!")
                            readyToRejoin = true
                            if watchdogConnection then watchdogConnection:Disconnect() end
                        end
                    end
                elseif data.type == "event" then
                    print(string.format("[WS] Event: %s", data.event))
                end
            end
        end)

        ws.OnClose:Connect(function()
            wsConnected = false
            ws = nil
            print("[WS] Disconnected, reconnecting in 5s...")
            task.wait(5)
            setupWebSocket()
        end)

        return true
    else
        print("[WS] Failed to connect:", tostring(result))
        task.wait(5)
        setupWebSocket()
        return false
    end
end

-- Connect WebSocket
setupWebSocket()

-- ==================== SEND VIA WEBSOCKET ====================
local function sendWS(payload)
    if ws and wsConnected then
        pcall(function()
            ws:Send(HttpService:JSONEncode(payload))
        end)
    end
end

local function sendLose(username)
    sendWS({ Lose = username })
    sendWS({ instaFail = true })
end

local function sendRecovered(username)
    sendWS({ Recovered = username })
    sendWS({ instaFail = false })
end

local function sendDupeTrue()
    sendWS({ Dupe = true })
end

local function sendCheckTrue()
    sendWS({ Check = true })
end

