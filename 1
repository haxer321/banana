-- DEBUG SCRIPT - Place this at the beginning of your main script
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local debugInfo = {
    startTime = tick(),
    checks = {},
    framesFound = false,
    framesFoundTime = nil,
    gemsValue = nil,
    gemsCheckTime = nil,
    guiPathExists = false,
    guiChildrenCount = 0,
    frameNames = {},
    failReported = false,
    reason = nil
}

-- Function to log debug info
local function logDebug(message, category)
    local timestamp = string.format("%.2f", tick() - debugInfo.startTime)
    print(string.format("[DEBUG][%ss][%s] %s", timestamp, category or "INFO", message))
end

-- Function to check current gems value safely
local function getGemsValue()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local gems = leaderstats:FindFirstChild("Gems")
        if gems then
            return gems.Value
        end
    end
    return nil
end

-- Function to inspect GUI thoroughly
local function inspectGUI()
    local success, result = pcall(function()
        local guiPath = player:WaitForChild("PlayerGui", 5)
        if not guiPath then return "No PlayerGui" end
        
        local lobby = guiPath:FindFirstChild("Lobby")
        if not lobby then return "No Lobby" end
        
        local postOffice = lobby:FindFirstChild("PostOffice")
        if not postOffice then return "No PostOffice" end
        
        local menus = postOffice:FindFirstChild("Menus")
        if not menus then return "No Menus" end
        
        local receivePackages = menus:FindFirstChild("ReceivePackages")
        if not receivePackages then return "No ReceivePackages" end
        
        local scrollingFrame = receivePackages:FindFirstChild("ScrollingFrame")
        if not scrollingFrame then return "No ScrollingFrame" end
        
        debugInfo.guiPathExists = true
        
        local children = scrollingFrame:GetChildren()
        debugInfo.guiChildrenCount = #children
        
        local frames = {}
        for _, child in ipairs(children) do
            if child:IsA("Frame") then
                table.insert(frames, child.Name)
                debugInfo.framesFound = true
                debugInfo.framesFoundTime = tick() - debugInfo.startTime
            end
        end
        debugInfo.frameNames = frames
        
        return "Success", #frames
    end)
    
    if not success then
        return "Error: " .. tostring(result)
    end
    return result
end

-- Main debug loop - runs parallel to your main script
task.spawn(function()
    logDebug("Debug script started", "INIT")
    logDebug("Player: " .. player.Name, "INIT")
    
    -- Wait for game to load
    if not game:IsLoaded() then
        game.Loaded:Wait()
        logDebug("Game loaded", "LOAD")
    end
    
    -- Monitor every second
    while task.wait(1) do
        local currentGems = getGemsValue()
        local elapsed = tick() - debugInfo.startTime
        
        -- Check for win condition
        if currentGems and currentGems == 5000000 then
            logDebug("WIN CONDITION MET! Gems = " .. currentGems, "WIN")
            debugInfo.reason = "WIN - No fail reported"
        end
        
        -- At 20 seconds, analyze why fail would be reported
        if elapsed >= 20 and not debugInfo.failReported then
            debugInfo.failReported = true
            logDebug("=== 20 SECOND ANALYSIS ===", "FAIL_CHECK")
            
            -- Re-inspect GUI
            local inspectResult = inspectGUI()
            logDebug("GUI Inspection: " .. tostring(inspectResult), "FAIL_CHECK")
            
            -- Check gems again
            local finalGems = getGemsValue()
            logDebug("Final Gems value: " .. tostring(finalGems), "FAIL_CHECK")
            
            -- Determine WHY fail would be reported
            local failReasons = {}
            
            if not debugInfo.guiPathExists then
                table.insert(failReasons, "GUI path doesn't exist (missing Lobby/PostOffice/Menus/ReceivePackages/ScrollingFrame)")
            elseif not debugInfo.framesFound then
                table.insert(failReasons, string.format("GUI path exists but NO FRAMES found in ScrollingFrame (has %d total children)", debugInfo.guiChildrenCount))
                if debugInfo.guiChildrenCount > 0 then
                    local childTypes = {}
                    -- Need to re-get children for type check
                    pcall(function()
                        local guiPath = player.PlayerGui.Lobby.PostOffice.Menus.ReceivePackages.ScrollingFrame
                        for _, child in ipairs(guiPath:GetChildren()) do
                            childTypes[child.ClassName] = (childTypes[child.ClassName] or 0) + 1
                        end
                        logDebug("Child types found: " .. HttpService:JSONEncode(childTypes), "FAIL_CHECK")
                    end)
                end
            else
                table.insert(failReasons, string.format("FOUND %d frames! Fail would NOT be reported", #debugInfo.frameNames))
                logDebug("Frame names found: " .. table.concat(debugInfo.frameNames, ", "), "FAIL_CHECK")
            end
            
            if finalGems == 5000000 then
                table.insert(failReasons, "BUT gems already at 5,000,000 - fail is SKIPPED (correct behavior)")
            elseif finalGems then
                table.insert(failReasons, string.format("Current gems: %d (not at target)", finalGems))
            else
                table.insert(failReasons, "Cannot read gems value (leaderstats/Gems missing)")
            end
            
            -- Print final verdict
            logDebug("=== FAIL VERDICT ===", "RESULT")
            for i, reason in ipairs(failReasons) do
                logDebug(reason, "RESULT")
            end
            
            if not debugInfo.framesFound and debugInfo.guiPathExists and finalGems ~= 5000000 then
                logDebug("🔴 FAIL WOULD BE REPORTED: No frames found after 20s", "RESULT")
            elseif debugInfo.framesFound then
                logDebug("🟢 FAIL WOULD NOT BE REPORTED: Frames were found", "RESULT")
            elseif finalGems == 5000000 then
                logDebug("🟢 FAIL WOULD NOT BE REPORTED: Already at 5M gems", "RESULT")
            else
                logDebug("🟡 UNCLEAR: " .. table.concat(failReasons, ", "), "RESULT")
            end
        end
        
        -- Log every 5 seconds for visibility
        if math.floor(elapsed) % 5 == 0 and elapsed > 0 then
            local frameStatus = debugInfo.framesFound and "FOUND" or "NOT FOUND YET"
            logDebug(string.format("Status at %.0fs: Gems=%s, Frames=%s", elapsed, tostring(currentGems), frameStatus), "STATUS")
        end
    end
end)

-- Also add a one-time check immediately when the GUI should be available
task.wait(3) -- Wait a bit for GUI to load
local initialCheck = inspectGUI()
logDebug("Initial GUI check: " .. tostring(initialCheck), "INIT")
if debugInfo.frameNames and #debugInfo.frameNames > 0 then
    logDebug("Initial frames found: " .. table.concat(debugInfo.frameNames, ", "), "INIT")
end

print("\n[DEBUG] Debug script running - check output for 'FAIL_VERDICT' at 20 seconds\n")
