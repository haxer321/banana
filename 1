-- ==================== MAIN LOOP ====================
print("[MAIN] Starting main loop - Account: " .. player.Name)

while task.wait() do
    
    -- NO serverBusy check here anymore
    
    local leaderstats = player:FindFirstChild("leaderstats")
    local gems = leaderstats and leaderstats:FindFirstChild("Gems")

    -- SUCCESS: reached 5M gems
    if gems and gems.Value == 5000000 then
        if not sentRecovered and not hasLeft then
            print(string.format("[MAIN] Gems = %d - RECOVERED! Sending Recovered...", gems.Value))
            sentRecovered = true

            pcall(function()
                sendRecovered(player.Name)
            end)

            task.wait(0.5)

            print("[MAIN] Sending Dupe=true and leaving...")
            leaveAndWaitForNextCycle()
            break
        end
    end

    -- FAIL: no frames after 20 seconds
    if not sentFail then
        local frameFound = false
        local elapsed = 0

        while elapsed < 20 do
            for _, child in ipairs(guiPath:GetChildren()) do
                if child:IsA("Frame") then
                    frameFound = true
                    break
                end
            end
            if frameFound then break end
            task.wait(0.5)
            elapsed = elapsed + 0.5
        end

        local currentGems = nil
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            local gemsObj = leaderstats:FindFirstChild("Gems")
            if gemsObj then
                currentGems = gemsObj.Value
            end
        end

        if currentGems == 5000000 then
            print("[INFO] Already at 5M, not reporting failure")
        elseif not frameFound then
            sentFail = true
            print("[INFO] No frames found after 20s - reporting failure")
            pcall(function()
                sendLose(player.Name)
            end)
        else
            print("[INFO] Frames found, skipping fail report")
        end
    end

    -- REMOTE FIRING
    for _, child in ipairs(guiPath:GetChildren()) do
        if child:IsA("Frame") then
            local args = { { { idValue, staticString, child.Name } } }
            remote:FireServer(unpack(args))
        end
    end
end
