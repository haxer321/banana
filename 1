-- ==================== GUI PATH ====================
local guiPath = player:WaitForChild("PlayerGui")
    :WaitForChild("Lobby")
    :WaitForChild("PostOffice")
    :WaitForChild("Menus")
    :WaitForChild("ReceivePackages")
    :WaitForChild("ScrollingFrame")

-- ==================== NETWORKING ====================
local remote = ReplicatedStorage:WaitForChild("NetworkingContainer"):WaitForChild("DataRemote")
local idValue = ReplicatedStorage:WaitForChild("IdentifiersContainer"):WaitForChild(
    "RF_59fb8da4c771fdd9e7348c3e113b4939ec60069b536a2ff0e2dd4f9e857a6611_S"
).Value
local staticString = "\218\231*\223\237\226@\151\148Y@7%\190&\159"

-- ==================== LEAVE AND WAIT FOR CHECK ====================
local function leaveAndWaitForNextCycle()
    print("[LEAVE] Account: " .. player.Name)

    -- Send Dupe=true (one time)
    sendDupeTrue()
    print("[LEAVE] Sent Dupe=true")

    task.wait(0.5)

    -- Leave game
    print("[LEAVE] Leaving game...")
    hasLeft = true
    player:Kick("Dupe sent - waiting for Check=true (next cycle)")

    -- Watchdog: wait for Check to become true (next cycle)
    task.spawn(function()
        print("[WATCHDOG] Waiting for Check=true (next cycle)...")

        if ws and ws.OnMessage then
            watchdogConnection = ws.OnMessage:Connect(function(msg)
                local ok, data = pcall(function()
                    return HttpService:JSONDecode(msg)
                end)
                if ok and data and data.type == "state" and data.state then
                    local check = data.state.Check
                    if check == true then
                        print("[WATCHDOG] Check=true! Rejoining now...")
                        readyToRejoin = true
                        if watchdogConnection then
                            watchdogConnection:Disconnect()
                            watchdogConnection = nil
                        end
                    end
                end
            end)
        end

        -- Timeout after 5 minutes (avoid infinite wait)
        task.spawn(function()
            task.wait(300)
            if not readyToRejoin then
                print("[WATCHDOG] Timeout - forcing rejoin")
                readyToRejoin = true
            end
        end)

        while not readyToRejoin do
            task.wait(0.5)
        end

        task.wait(1)
        print("[WATCHDOG] Teleporting back to game...")
        TeleportService:Teleport(game.PlaceId, player)
    end)
end

-- ==================== AFTER REJOIN: COMPLETE DUPE ====================
local function completeDupeAfterRejoin()
    print("[COMPLETE] Rejoined! Sending Check=true to complete dupe...")
    sendCheckTrue()
    print("[COMPLETE] Check=true sent. Dupe finished.")
end

-- Detect if we just rejoined (script restarts after teleport)
task.spawn(function()
    task.wait(2)
    if hasLeft then
        completeDupeAfterRejoin()
    end
end)

-- ==================== MAIN LOOP ====================
print("[MAIN] Starting main loop - Account: " .. player.Name)

while task.wait() do
    local leaderstats = player:FindFirstChild("leaderstats")
    local gems = leaderstats and leaderstats:FindFirstChild("Gems")

    -- SUCCESS: reached 5M gems
    if gems and gems.Value == 5000000 then
        if not sentRecovered and not hasLeft then
            print(string.format("[MAIN] Gems = %d - RECOVERED! Sending Recovered...", gems.Value))
            sentRecovered = true

            pcall(function()
                sendRecovered(player.Name)
            end)

            task.wait(0.5)

            print("[MAIN] Sending Dupe=true and leaving...")
            leaveAndWaitForNextCycle()
            break
        end
    end

    -- FAIL: no frames after 20 seconds
    if not sentFail then
        local frameFound = false
        local elapsed = 0

        while elapsed < 20 do
            for _, child in ipairs(guiPath:GetChildren()) do
                if child:IsA("Frame") then
                    frameFound = true
                    break
                end
            end
            if frameFound then break end
            task.wait(0.5)
            elapsed = elapsed + 0.5
        end

        local currentGems = nil
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            local gemsObj = leaderstats:FindFirstChild("Gems")
            if gemsObj then
                currentGems = gemsObj.Value
            end
        end

        if currentGems == 5000000 then
            print("[INFO] Already at 5M, not reporting failure")
        elseif not frameFound then
            sentFail = true
            print("[INFO] No frames found after 20s - reporting failure")
            pcall(function()
                sendLose(player.Name)
            end)
        else
            print("[INFO] Frames found, skipping fail report")
        end
    end

    -- REMOTE FIRING (dupe logic inside game)
    for _, child in ipairs(guiPath:GetChildren()) do
        if child:IsA("Frame") then
            local args = { { { idValue, staticString, child.Name } } }
            remote:FireServer(unpack(args))
        end
    end
end
