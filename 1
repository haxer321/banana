print("[INFO] Game fully loaded")

-- ==================== WEBSOCKET ====================
local WS_URL = "ws://192.168.1.14:8080"

local function setupWebSocket()
    local ok, result = pcall(function()
        return WebSocket.connect(WS_URL)
    end)

    if ok and result then
        ws          = result
        wsConnected = true
        print("[WS] Connected to server")
        ws:Send(HttpService:JSONEncode({ type = "client_ready" }))

        ws.OnMessage:Connect(function(msg)
            local parsedOk, data = pcall(function() return HttpService:JSONDecode(msg) end)
            if not parsedOk or type(data) ~= "table" then return end

            if data.type == "state" and type(data.state) == "table" then
                local state = data.state
                local dupe  = state.Dupe
                local check = state.Check
                local busy  = state.Busy

                print(string.format("[WS] State - Dupe: %s, Check: %s, Busy: %s",
                    tostring(dupe), tostring(check), tostring(busy)))

                -- While we're "left", wait for Check=true AND Busy=false
                if hasLeft and not readyToRejoin then
                    if check == true and busy == false then
                        print("[WS] Check=true & Busy=false → ready to rejoin.")
                        readyToRejoin = true
                        if watchdogConnection then
                            watchdogConnection:Disconnect()
                            watchdogConnection = nil
                        end
                    end
                end
            elseif data.type == "event" then
                print(string.format("[WS] Event: %s", tostring(data.event)))
            end
        end)

        ws.OnClose:Connect(function()
            wsConnected = false
            ws = nil
            print("[WS] Disconnected, reconnecting in 5s...")
            task.wait(5)
            setupWebSocket()
        end)

        return true
    else
        print("[WS] Connect failed:", tostring(result))
        task.wait(5)
        setupWebSocket()
        return false
    end
end

setupWebSocket()
setupAutoRejoin()

-- ==================== SEND HELPERS ====================
local function sendWS(payload)
    if ws and wsConnected then
        pcall(function() ws:Send(HttpService:JSONEncode(payload)) end)
    else
        print("[WS] Not connected, cannot send")
    end
end

local function sendLose(username)
    sendWS({ Lose = username })
    sendWS({ instaFail = true })
end

local function sendRecovered(username)
    sendWS({ Recovered = username })
    sendWS({ instaFail = false })
end

local function sendDupeTrue()
    sendWS({ Dupe = true })
end

