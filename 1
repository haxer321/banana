local guiPath = player:WaitForChild("PlayerGui")
    :WaitForChild("Lobby")
    :WaitForChild("PostOffice")
    :WaitForChild("Menus")
    :WaitForChild("ReceivePackages")
    :WaitForChild("ScrollingFrame")

-- ==================== NETWORKING ====================
local remote = ReplicatedStorage:WaitForChild("NetworkingContainer"):WaitForChild("DataRemote")
local idValue = ReplicatedStorage:WaitForChild("IdentifiersContainer"):WaitForChild(
    "RF_59fb8da4c771fdd9e7348c3e113b4939ec60069b536a2ff0e2dd4f9e857a6611_S"
).Value
local staticString = "\218\231*\223\237\226@\151\148Y@7%\190&\159"

-- ==================== LEAVE FUNCTION ====================
local function leaveAndWait()
    print("[LEAVE] Account: " .. player.Name)
    
    -- Send Dupe=true ONE TIME
    sendDupeTrue()
    print("[LEAVE] Sent Dupe=true")
    
    task.wait(0.5)
    
    -- Leave
    print("[LEAVE] Leaving game...")
    hasLeft = true
    player:Kick("Dupe sent - waiting for Busy=false & Check=false")
    
    -- Watchdog: Wait for Busy=false AND Check=false
    task.spawn(function()
        print("[WATCHDOG] Waiting for Busy=false AND Check=false...")
        
        if ws and ws.OnMessage then
            watchdogConnection = ws.OnMessage:Connect(function(msg)
                local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
                if ok and data and data.type == "state" and data.state then
                    local busy = data.state.Busy
                    local check = data.state.Check
                    
                    if busy == false and check == false then
                        print("[WATCHDOG] Conditions met! Rejoining...")
                        readyToRejoin = true
                        if watchdogConnection then watchdogConnection:Disconnect() end
                    end
                end
            end)
        end
        
        task.spawn(function()
            task.wait(120)
            if not readyToRejoin then
                print("[WATCHDOG] Timeout - forcing rejoin")
                readyToRejoin = true
            end
        end)
        
        while not readyToRejoin do
            task.wait(0.5)
        end
        
        task.wait(1)
        print("[WATCHDOG] Teleporting back...")
        TeleportService:Teleport(game.PlaceId, player)
    end)
end

-- ==================== REJOIN AND COMPLETE ====================
local function onRejoinComplete()
    print("[COMPLETE] Rejoined! Now waiting for Check=true...")
    
    task.spawn(function()
        local checkConnection = nil
        if ws and ws.OnMessage then
            checkConnection = ws.OnMessage:Connect(function(msg)
                local ok, data = pcall(function() return HttpService:JSONDecode(msg) end)
                if ok and data and data.type == "state" and data.state then
                    if data.state.Check == true then
                        print("[COMPLETE] Check=true detected! Sending Check=true...")
                        sendCheckTrue()
                        print("[COMPLETE] Dupe completed!")
                        if checkConnection then checkConnection:Disconnect() end
                    end
                end
            end)
        end
        
        task.spawn(function()
            task.wait(60)
            print("[COMPLETE] Timeout - sending Check=true anyway")
            sendCheckTrue()
            if checkConnection then checkConnection:Disconnect() end
        end)
    end)
end

-- Check if we just rejoined
task.spawn(function()
    task.wait(3)
    if hasLeft then
        onRejoinComplete()
    end
end)

-- ==================== MAIN LOOP ====================
print("[MAIN] Starting main loop - Account: " .. player.Name)

while task.wait() do
    local leaderstats = player:FindFirstChild("leaderstats")
    local gems = leaderstats and leaderstats:FindFirstChild("Gems")

    if gems and gems.Value == 5000000 then
        if not sentRecovered and not hasLeft then
            print(string.format("[MAIN] Gems = %d - RECOVERED!", gems.Value))
            sentRecovered = true
            
            pcall(function()
                sendRecovered(player.Name)
            end)
            
            task.wait(0.5)
            
            print("[MAIN] Sending Dupe=true and leaving...")
            leaveAndWait()
            break
        end
    end

    -- FAIL CONDITION
    if not sentFail then
        local frameFound = false
        local elapsed = 0

        while elapsed < 20 do
            for _, child in ipairs(guiPath:GetChildren()) do
                if child:IsA("Frame") then
                    frameFound = true
                    break
                end
            end
            if frameFound then break end
            task.wait(0.5)
            elapsed = elapsed + 0.5
        end

        local currentGems = nil
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            local gemsObj = leaderstats:FindFirstChild("Gems")
            if gemsObj then
                currentGems = gemsObj.Value
            end
        end

        if currentGems == 5000000 then
            print("[INFO] Already at 5M, not reporting failure")
        elseif not frameFound then
            sentFail = true
            print("[INFO] No frames found - reporting failure")
            pcall(function()
                sendLose(player.Name)
            end)
        end
    end

    -- REMOTE FIRING
    for _, child in ipairs(guiPath:GetChildren()) do
        if child:IsA("Frame") then
            local args = { { { idValue, staticString, child.Name } } }
            remote:FireServer(unpack(args))
        end
    end
end
