-- =============================================
-- REJECT HELPERS (with flexible sender detection)
-- =============================================
local function rejectFrameByName(frameName, maxWait)
    maxWait = maxWait or 15
    local elapsed = 0
    print("[REJECT] Attempting to reject frame: " .. frameName)
    while elapsed < maxWait do
        local found = false
        for _, frame in ipairs(scrollingFrame:GetChildren()) do
            if frame.Name == frameName then found = true; break end
        end
        if not found then
            print("[REJECT] ✅ Frame " .. frameName .. " is gone (rejected successfully)")
            return true
        end
        print("[REJECT] Firing reject remote for " .. frameName)
        remote:FireServer({ {rejectId, rejectStr, frameName} })
        task.wait(0.2)
        elapsed = elapsed + 0.2
    end
    print("[REJECT] ❌ Timeout: Frame " .. frameName .. " still exists after " .. maxWait .. "s")
    return false
end

-- Find a frame that contains a TextBox/TextLabel whose text matches the username (case-insensitive, ignoring @)
local function findFrameByUser(user)
    local userClean = user:gsub("@", ""):lower()
    for _, frame in ipairs(scrollingFrame:GetChildren()) do
        if frame:IsA("Frame") then
            -- First, look for a child named "From" (TextBox or TextLabel)
            local fromBox = frame:FindFirstChild("From")
            if fromBox and (fromBox:IsA("TextBox") or fromBox:IsA("TextLabel")) then
                local text = fromBox.Text:gsub("@", ""):lower()
                if text == userClean then
                    return frame
                end
            end
            -- If not found, scan all TextBox/TextLabel descendants
            for _, desc in ipairs(frame:GetDescendants()) do
                if (desc:IsA("TextBox") or desc:IsA("TextLabel")) and desc.Text then
                    local text = desc.Text:gsub("@", ""):lower()
                    if text == userClean then
                        return frame
                    end
                end
            end
        end
    end
    return nil
end

-- Main rejection function with blocklist
local function rejectAllFails()
    if not FAILS or #FAILS == 0 then
        return
    end
    print("[FAIL] ***** STARTING REJECTION OF " .. #FAILS .. " FAILS *****")
    print("[FAIL] Fail list: " .. table.concat(FAILS, ", "))
    for _, badUser in ipairs(FAILS) do
        -- Check blocklist
        if blockedUsers[badUser] then
            print("[FAIL] ⏭️ Ignoring " .. badUser .. " (already blocked, waiting for dupe == true)")
            continue
        end
        print("[FAIL] Looking for frame for user: " .. badUser)
        local frame = findFrameByUser(badUser)
        if frame then
            print("[FAIL] Found frame with name: " .. frame.Name)
            local success = rejectFrameByName(frame.Name, 15)
            if success then
                -- Add to blocklist
                blockedUsers[badUser] = true
                print("[FAIL] ✅ Rejected " .. badUser .. " successfully! Added to blocklist.")
            else
                print("[FAIL] ❌ Failed to reject " .. badUser .. " (timeout) – not blocking.")
            end
        else
            print("[FAIL] ❌ Could not find frame for user: " .. badUser)
            -- Debug dump: show all frames and their TextBox/TextLabel content
            print("[DEBUG] Current frames and their TextBox/TextLabel content:")
            for _, f in ipairs(scrollingFrame:GetChildren()) do
                if f:IsA("Frame") then
                    local texts = {}
                    for _, d in ipairs(f:GetDescendants()) do
                        if (d:IsA("TextBox") or d:IsA("TextLabel")) and d.Text then
                            table.insert(texts, d.Text)
                        end
                    end
                    print("[DEBUG]   Frame " .. f.Name .. " → Texts: " .. table.concat(texts, " | "))
                end
            end
        end
    end
    print("[FAIL] ***** FINISHED REJECTION ATTEMPT *****")
end

-- =============================================
-- WS CONNECTION + MESSAGE HANDLER
-- =============================================
local function connectWS()
    print("[WSS] Syncing with Android...")
    local ok, socket = pcall(function() return WebSocket.connect(WS_URL) end)
    if not ok or not socket then
        task.wait(5)
        return connectWS()
    end
    ws = socket

    ws:Send(HttpService:JSONEncode({ type = "priority_set", user = player.Name }))
    print("[WSS] Sent priority claim for " .. player.Name)

    local priorityConfirmed = false
    ws.OnMessage:Connect(function(msg)
        local ok2, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok2 then return end

        if data.user == player.Name then
            if not priorityConfirmed then
                priorityConfirmed = true
                print("[WSS] Priority implicitly confirmed")
            end
        end

        if data.type == "data_update" then
            TARGET    = tonumber(data.target) or 0
            DUPE_FLAG = (data.Dupe == true)
            CHECK_FLAG= (data.Check == true)
            FAILS     = data.Fails or data.fails or {}
            print("[WSS] 📨 Data Update: Target=" .. TARGET .. " Dupe=" .. tostring(DUPE_FLAG) .. " Check=" .. tostring(CHECK_FLAG))
            print("[WSS] 📋 Received FAILS table: " .. table.concat(FAILS, ", "))

            -- If dupe == true, release all blocks
            if DUPE_FLAG then
                if next(blockedUsers) then
                    local count = 0
                    for _ in pairs(blockedUsers) do count = count + 1 end
                    print("[DUPE] 🧹 Dupe is true – clearing blocklist (" .. count .. " users)")
                    blockedUsers = {}
                else
                    print("[DUPE] Dupe is true, but blocklist is already empty.")
                end
            end

            -- Immediate rejection (spawn so it doesn't block)
            task.spawn(function()
                rejectAllFails()
            end)
        end
    end)

    local timeout = os.clock() + 5
    while os.clock() < timeout and not priorityConfirmed do
        task.wait(0.1)
    end
    if not priorityConfirmed then
        print("[WSS] No confirmation within 5s, proceeding anyway...")
    end

    ws.OnClose:Connect(function()
        print("[WSS] Connection closed. Reconnecting in 2s...")
        task.wait(2)
        connectWS()
    end)
end

