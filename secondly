    while os.clock() < deadline do
        if DUPE_FLAG == true then break end -- Confirmation signal
        task.wait(1)
        if ws then ws:Send(HttpService:JSONEncode({ type = "get_data" })) end
    end

    -- Signal Success
    guiStatus.Text = "✅ Complete! Finalizing..."
    ws:Send(HttpService:JSONEncode({ type = "complete" }))
    task.wait(2)
    player:Kick("Protocol Successful")
    break
end
