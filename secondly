        for _, v in ipairs(scrollingFrame:GetChildren()) do if v:IsA("Frame") then count = count + 1 end end
        if count >= TARGET then break end
        task.wait(1)
    end

    ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Stop" }))

    -- Confirmation Phase
    guiStatus.Text = "⌛ Waiting for Server Success..."
