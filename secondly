end)

local HttpService = game:GetService("HttpService")
local Players     = game:GetService("Players")
local player      = Players.LocalPlayer
local WS_URL      = "ws://localhost:8080"
local ws          = nil

-- CONFIG & STATE
local TARGET      = 4       -- Hardcoded: 4 pkgs = 10M Gems
local FAILS       = {}      -- List of failed usernames from server
local DUPE_FLAG   = false
local CHECK_FLAG  = true
local TELEPORT    = CFrame.new(-460, 244, -67)

-- BLOCKLIST (Prevents spam-rejecting the same user in one cycle)
local blockedUsers = {}

-- ROBLOX ELEMENTS
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local remote = ReplicatedStorage:WaitForChild("NetworkingContainer"):WaitForChild("DataRemote")
local playerGui = player:WaitForChild("PlayerGui")
local scrollingFrame = playerGui:WaitForChild("Lobby"):WaitForChild("PostOffice"):WaitForChild("Menus"):WaitForChild("ReceivePackages"):WaitForChild("ScrollingFrame")

local rejectId = ReplicatedStorage:WaitForChild("IdentifiersContainer"):WaitForChild("RF_9ff1f197bac1aed0e111d8b6c30732ea1a98d77594aa860e7ec9dae51fc194e5_S").Value
local rejectStr = "\175+\190\168z\137N\150\168}\161C\201\240\178\204"

-- ===================== REJECT SYSTEM =====================

local function fireReject(frameName)
    print("[REJECT] Removing frame: " .. frameName)
    remote:FireServer({ {rejectId, rejectStr, frameName} })
end

local function processSmartFails()
    if not FAILS or #FAILS == 0 then return end
    
    local unresolvedFails = {}
    for _, u in ipairs(FAILS) do 
        local name = u:gsub("@",""):lower()
        if not blockedUsers[name] then unresolvedFails[name] = true end
    end
    
    if not next(unresolvedFails) then return end

    local unknownFrames = {}

    -- Phase 1: Name Match & Gather Unknowns
    for _, frame in ipairs(scrollingFrame:GetChildren()) do
        if not frame:IsA("Frame") then continue end
        
        local senderName = "unknown"
        local p = frame:FindFirstChild("Package")
        local f = p and p:FindFirstChild("From")
        if f then senderName = f.Text:gsub("@",""):lower() end

        if unresolvedFails[senderName] then
            print("[FAIL] Found by Name: " .. senderName)
            fireReject(frame.Name)
            blockedUsers[senderName] = true
            unresolvedFails[senderName] = nil
        elseif senderName:find("unknown") then
            table.insert(unknownFrames, frame)
        end
    end

    -- Phase 2: Scan Unknowns' Content for fail names
    for i = #unknownFrames, 1, -1 do
        local frame = unknownFrames[i]
        local foundInMsg = false
        
        for _, desc in ipairs(frame:GetDescendants()) do
            if (desc:IsA("TextLabel") or desc:IsA("TextBox")) and desc.Text then
                local txt = desc.Text:lower()
                for badUser, _ in pairs(unresolvedFails) do
                    if txt:find(badUser) then
                        print("[FAIL] Found " .. badUser .. " inside @Unknown note!")
                        fireReject(frame.Name)
                        blockedUsers[badUser] = true
                        unresolvedFails[badUser] = nil
                        table.remove(unknownFrames, i)
                        foundInMsg = true
                        break
                    end
                end
            end
            if foundInMsg then break end
        end
    end

    -- Phase 3: Aggressive Fallback (Reject any @Unknown if we still have unresolved fails)
    if #unknownFrames > 0 and next(unresolvedFails) then
        print("[FAIL] Unresolved fails exist. Purging " .. #unknownFrames .. " unidentifiable packages.")
        for _, frame in ipairs(unknownFrames) do
            fireReject(frame.Name)
        end
    end
end

-- ===================== WS COMMUNICATION =====================

local function connectWS()
    print("[WSS] Syncing with Android Service...")
    local ok, socket = pcall(function() return WebSocket.connect(WS_URL) end)
    if not ok or not socket then task.wait(5); return connectWS() end
    ws = socket

    -- Set priority on connect
    ws:Send(HttpService:JSONEncode({ type = "priority_set", user = player.Name }))

    ws.OnMessage:Connect(function(msg)
        local ok2, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok2 or data.type ~= "data_update" then return end

        TARGET = 4 -- Force target to 4
        FAILS  = data.Fails or data.fails or {}
        
        -- Reset blocks on new dupe cycle
        if data.Dupe == true and not DUPE_FLAG then
            print("[WSS] Cycle Reset: Clearing Rejection Cache")
            blockedUsers = {}
        end
        
        DUPE_FLAG = (data.Dupe == true)
        CHECK_FLAG = (data.Check == true)
    end)

    ws.OnClose:Connect(function() 
        print("[WSS] Connection lost! Retrying...")
        task.wait(2); connectWS() 
    end)
end

