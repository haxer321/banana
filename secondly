local function getFrames()
    local out = {}
    for _, f in pairs(frameCache) do table.insert(out, f) end
    return out
end

scrollingFrame.ChildAdded:Connect(function(c)
    if c:IsA("Frame") then
        frameCache[c.Name] = c
        frameCount = frameCount + 1
    end
end)
scrollingFrame.ChildRemoved:Connect(function(c)
    if c:IsA("Frame") and frameCache[c.Name] then
        frameCache[c.Name] = nil
        frameCount = frameCount - 1
        if frameCount < 0 then frameCount = 0 end
    end
end)

-- =============================================
-- NAME / MESSAGE EXTRACTION
-- =============================================
local function getFrameSender(frame)
    if not frame or not frame:IsA("Frame") then return "unknown" end
    local pkg = frame:FindFirstChild("Package")
    if not pkg then return "unknown" end
    local from = pkg:FindFirstChild("From")
    if from and from:IsA("TextLabel") then
        local txt = from.Text or ""
        txt = txt:gsub("@",""):lower()
        if txt ~= "" then return txt end
    end
    return "unknown"
end

local function getFrameMessage(frame)
    local pkg = frame:FindFirstChild("Package")
    if not pkg then return "" end
    local msg = pkg:FindFirstChild("Message")
    if msg and msg:IsA("TextLabel") then return msg.Text or "" end
    return ""
end

local function findFailsInText(text, unresolved)
    if not text then return nil end
    local lowered = text:lower()
    for badUser in pairs(unresolved) do
        if badUser and badUser ~= "" and lowered:find(badUser, 1, true) then
            return badUser
        end
    end
    return nil
end

local function stripInvisible(str)
    if not str then return "" end
    local filtered = {}
    for i = 1, #str do
        local byte = str:byte(i)
        if byte >= 32 and byte <= 126 then
            table.insert(filtered, str:sub(i, i))
        end
    end
    return table.concat(filtered)
end

local function hasAlnum(str)
    if not str then return false end
    return str:match("%w") ~= nil
end

-- =============================================
-- ⚡ VIM-AWARE FAIL PROCESSOR
-- =============================================
local function processFailsVIM()
    if KILL or #FAILS == 0 then return end
    
    local now = os.clock()
    local unresolved = {}
    
    for _, user in ipairs(FAILS) do
        local name = user:gsub("@",""):lower()
        if name ~= "" and not blockedUsers[name] then
            unresolved[name] = true
            if not failTimestamps[name] then failTimestamps[name] = now end
        end
    end
    
    if next(unresolved) == nil then return end
    
    -- Get all current frames
    local frames = scrollingFrame:GetChildren()
    
    -- Find frames to reject (check in order)
    for _, frame in ipairs(frames) do
        if not frame:IsA("Frame") then continue end
        
        local sender = stripInvisible(getFrameSender(frame))
        local message = stripInvisible(getFrameMessage(frame))
        local senderLower = (sender:gsub("@",""):lower())
        if not hasAlnum(senderLower) then senderLower = "unknown" end
        local msgHasAlnum = hasAlnum(message)
        
        -- Corrupt frame (unknown sender + no message content)
        if senderLower == "unknown" and not msgHasAlnum then
            if rejectFrameVIM(frame) then
                return  -- Stop after one successful rejection (cooldown active)
            end
            continue
        end
        
        -- Unknown sender but message contains a fail name
        if senderLower == "unknown" then
            local matched = findFailsInText(message, unresolved)
            if matched then
                if rejectFrameVIM(frame) then
                    blockedUsers[matched] = true
                    return
                end
                continue
            end
        end
        
        -- Direct sender match
        if unresolved[senderLower] then
            if rejectFrameVIM(frame) then
                blockedUsers[senderLower] = true
                failTimestamps[senderLower] = nil
                return
            end
            continue
        end
        
        -- Sender text contains fail name
        local matched = findFailsInText(sender, unresolved)
        if matched then
            if rejectFrameVIM(frame) then
                blockedUsers[matched] = true
                failTimestamps[matched] = nil
                return
            end
            continue
        end
    end
end

