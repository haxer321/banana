-- =============================================
-- ⚡ SIMPLIFIED QUEUE - ONE AT A TIME, NO BS
-- =============================================
local rejectQueue = {}
local processingFrame = nil
local lastRejectTime = 0
local COOLDOWN = 2.5

local function processNextInQueue()
    if processingFrame or KILL then return end
    
    -- Find next valid frame
    local frameToProcess = nil
    local frameIndex = nil
    
    for i, f in ipairs(rejectQueue) do
        if f and f.Parent then
            frameToProcess = f
            frameIndex = i
            break
        end
    end
    
    if not frameToProcess then
        -- Clear invalid entries
        rejectQueue = {}
        return
    end
    
    -- Remove from queue
    table.remove(rejectQueue, frameIndex)
    
    -- Wait for cooldown
    local now = tick()
    local waitTime = COOLDOWN - (now - lastRejectTime)
    if waitTime > 0 then
        task.wait(waitTime)
    end
    
    if KILL then return end
    if not frameToProcess.Parent then return end
    
    processingFrame = frameToProcess
    currentAction = "Rejecting: " .. frameToProcess.Name
    print("[REJECT] Start: " .. frameToProcess.Name)
    
    -- Get button
    local denyBtn = getDenyButton(frameToProcess)
    if not denyBtn then
        print("[REJECT] No button found")
        processingFrame = nil
        return
    end
    
    -- BRUTE FORCE CLICK
    bruteForceClick(denyBtn)
    
    -- Wait and verify
    local startTime = tick()
    local maxWait = 6
    
    while frameToProcess.Parent and (tick() - startTime) < maxWait do
        task.wait(0.15)
        
        -- If still there after 1 second, click again aggressively
        if frameToProcess.Parent and (tick() - startTime) > 1 then
            denyBtn = getDenyButton(frameToProcess)
            if denyBtn then
                bruteForceClick(denyBtn)
            end
        end
        
        -- If still there after 3 seconds, click again
        if frameToProcess.Parent and (tick() - startTime) > 3 then
            denyBtn = getDenyButton(frameToProcess)
            if denyBtn then
                bruteForceClick(denyBtn)
            end
        end
    end
    
    local success = not frameToProcess.Parent
    lastRejectTime = tick()
    processingFrame = nil
    
    if success then
        print("[REJECT] ✅ Done: " .. frameToProcess.Name)
    else
        print("[REJECT] ❌ Timeout: " .. frameToProcess.Name)
    end
    
    currentAction = "Idle"
    
    -- Process next if any
    task.wait(0.3)
    if #rejectQueue > 0 and not KILL then
        processNextInQueue()
    end
end

local function enqueueReject(frame)
    if not frame or not frame.Parent then return end
    
    -- Don't add if already processing this frame
    if processingFrame == frame then return end
    
    -- Don't add duplicates
    for _, f in ipairs(rejectQueue) do
        if f == frame then return end
    end
    
    table.insert(rejectQueue, frame)
    print("[QUEUE] Added: " .. frame.Name .. " (queue: " .. #rejectQueue .. ")")
    
    -- Start processing if idle
    if not processingFrame then
        task.spawn(processNextInQueue)
    end
end

