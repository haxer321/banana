end

-- ===================== NAME EXTRACTION =====================
-- Extracts the sender name from a frame by checking:
--   1) Package.From.Text  (the @mention)
--   2) Package.Message.Text (full message body, e.g. "Time: 06:19 shuttarmurgh")
-- Searches ALL frames and matches against unresolved FAILS list (case-insensitive).
local function getFrameSender(frame)
    if not frame or not frame:IsA("Frame") then return "unknown" end

    local pkg = frame:FindFirstChild("Package")
    if not pkg then return "unknown" end

    -- 1) Try the From label first
    local from = pkg:FindFirstChild("From")
    if from and from:IsA("TextLabel") and from.Text and from.Text ~= "" then
        local txt = from.Text:gsub("@",""):lower()
        if txt ~= "" and txt ~= "unknown" then
            return txt
        end
    end

    -- 2) Fallback: scan the entire Message text
    local msg = pkg:FindFirstChild("Message")
    if msg and msg:IsA("TextLabel") and msg.Text and msg.Text ~= "" then
        return msg.Text  -- returns raw text, will be scanned for substrings
    end

    -- 3) Final fallback: scan every TextLabel inside Package
    for _, d in ipairs(pkg:GetDescendants()) do
        if d:IsA("TextLabel") and d.Text and d.Text ~= "" then
            return d.Text
        end
    end

    return "unknown"
end

-- Helper to get the message text from a package frame
local function getFrameMessage(frame)
    local pkg = frame:FindFirstChild("Package")
    if not pkg then return "" end
    local msg = pkg:FindFirstChild("Message")
    if msg and msg:IsA("TextLabel") then
        return msg.Text or ""
    end
    return ""
end

-- Checks if a given text contains any of the unresolved fail names (case-insensitive)
local function findFailsInText(text, unresolved)
    if not text then return nil end
    local lowered = text:lower()
    for badUser, _ in pairs(unresolved) do
        if badUser and badUser ~= "" and lowered:find(badUser, 1, true) then
            return badUser
        end
    end
    return nil
end

-- Background logic for filtering fails and identifying @Unknown packages
local function processSmartFails()
    if KILL or not FAILS or #FAILS == 0 then return end
    local now = os.clock()
    local unresolved = {}

    for _, user in ipairs(FAILS) do
        local name = user:gsub("@",""):lower()
        if name ~= "" and not blockedUsers[name] then
            unresolved[name] = true
            if not failTimestamps[name] then failTimestamps[name] = now end
        end
    end

    if next(unresolved) == nil then return end

    local unknownFrames = {}
    for _, frame in ipairs(scrollingFrame:GetChildren()) do
        if not frame:IsA("Frame") then continue end

        local sender = getFrameSender(frame)
        local message = getFrameMessage(frame)
        local senderLower = (sender or "unknown"):gsub("@",""):lower()
        local messageTrimmed = message:gsub("%s+", "")

        -- ✨ NEW: Reject immediately if sender is @Unknown AND message is empty (corrupt)
        if senderLower == "unknown" and messageTrimmed == "" then
            currentAction = "Rejecting corrupt @Unknown with empty message"
            forceReject(frame.Name)
            currentAction = "Idle"
            -- skip further processing for this frame
            continue
        end

        -- Direct match against the From mention
        if unresolved[senderLower] then
            currentAction = "Rejecting failed sender: @" .. senderLower
            forceReject(frame.Name)
            blockedUsers[senderLower] = true
            failTimestamps[senderLower] = nil
            unresolved[senderLower] = nil
            currentAction = "Idle"
        else
            -- Deep scan the entire message text for unresolved names
            local matched = findFailsInText(sender, unresolved)
            if matched then
                currentAction = "Rejecting via message scan: @" .. matched
                forceReject(frame.Name)
                blockedUsers[matched] = true
                failTimestamps[matched] = nil
                unresolved[matched] = nil
                currentAction = "Idle"
            elseif senderLower:find("unknown") then
                table.insert(unknownFrames, frame)
            end
        end
    end

    -- 60s Fallback for Unresolved Fails
    for badUser, start in pairs(failTimestamps) do
        if now - start > 60 and #unknownFrames > 0 then
            print("[FALLBACK] Rejecting unknown for " .. badUser)
            currentAction = "Fallback reject for " .. badUser
            forceReject(unknownFrames[1].Name)
            blockedUsers[badUser] = true
            failTimestamps[badUser] = nil
            table.remove(unknownFrames, 1)
            currentAction = "Idle"
        end
    end
end

