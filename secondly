createGui()

local function updateGui(status)
    if KILL then return end
    if guiPkgLabel then
        guiPkgLabel.Text = "[PKG] " .. countPackages()
    end
    if guiStatusLabel and status then guiStatusLabel.Text = tostring(status) end
end

task.spawn(function()
    while not STOP and not KILL do task.wait(0.1); updateGui() end
end)

