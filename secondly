-- =============================================
-- ⚡ REJECTION SYSTEM (STRICT)
-- =============================================
local rejectQueue = {}
local isRejecting = false
local lastRejectComplete = 0
local REJECT_COOLDOWN = 3.0

local function doReject(frame)
    if not frame or not frame.Parent then
        print("[REJECT] Frame already gone")
        return true
    end
    
    local frameName = frame.Name
    currentAction = "Rejecting: " .. frameName
    print("[REJECT] Starting: " .. frameName)
    
    local denyBtn = getDenyButton(frame)
    if not denyBtn then
        print("[REJECT] ❌ No 'Deny' button found")
        return false
    end
    
    print("[REJECT] Found 'Deny', clicking...")
    local denyClicked = vimClickStrict(denyBtn, "Deny")
    
    if not denyClicked then
        print("[REJECT] ❌ Failed to click Deny")
        return false
    end
    
    print("[REJECT] Waiting for ConfirmReject dialog...")
    local confirmBtn = nil
    
    for i = 1, 50 do
        confirmBtn = getConfirmButton()
        if confirmBtn then
            print("[REJECT] ✅ Found 'Confirm' button")
            break
        end
        task.wait(0.1)
    end
    
    if not confirmBtn then
        print("[REJECT] ⚠️ No dialog, clicking Deny again...")
        denyBtn = getDenyButton(frame)
        if denyBtn then
            vimClickStrict(denyBtn, "Deny")
            for i = 1, 30 do
                confirmBtn = getConfirmButton()
                if confirmBtn then
                    print("[REJECT] ✅ Found 'Confirm' on second try")
                    break
                end
                task.wait(0.1)
            end
        end
    end
    
    if confirmBtn then
        task.wait(0.3)
        print("[REJECT] Clicking 'Confirm'...")
        local confirmClicked = vimClickStrict(confirmBtn, "Confirm")
        
        if not confirmClicked then
            print("[REJECT] ❌ Failed to click Confirm")
            return false
        end
        
        for i = 1, 50 do
            local alerts = postOfficeMenus:FindFirstChild("Alerts")
            if not alerts or not alerts.Visible then
                print("[REJECT] ✅ Dialog closed")
                break
            end
            task.wait(0.1)
        end
    else
        print("[REJECT] ❌ 'Confirm' button never appeared")
        return false
    end
    
    local startTime = tick()
    local maxWait = 8
    
    while frame.Parent and (tick() - startTime) < maxWait do
        task.wait(0.2)
    end
    
    local success = not frame.Parent
    if success then
        print("[REJECT] ✅ " .. frameName .. " rejected in " .. string.format("%.1f", tick() - startTime) .. "s")
    else
        print("[REJECT] ❌ " .. frameName .. " still present")
    end
    
    return success
end

local function processQueue()
    if isRejecting or KILL then return end
    if #rejectQueue == 0 then return end
    
    isRejecting = true
    
    while #rejectQueue > 0 and not KILL do
        local frameToReject = nil
        local frameIndex = nil
        
        for i, f in ipairs(rejectQueue) do
            if f and f.Parent then
                frameToReject = f
                frameIndex = i
                break
            end
        end
        
        if not frameToReject then
            rejectQueue = {}
            break
        end
        
        table.remove(rejectQueue, frameIndex)
        
        local now = tick()
        local waitTime = REJECT_COOLDOWN - (now - lastRejectComplete)
        if waitTime > 0 then
            task.wait(waitTime)
        end
        
        if KILL then break end
        
        doReject(frameToReject)
        lastRejectComplete = tick()
        task.wait(0.5)
    end
    
    isRejecting = false
    currentAction = "Idle"
end

local function enqueueReject(frame)
    if not frame or not frame.Parent then return end
    
    for _, f in ipairs(rejectQueue) do
        if f == frame then return end
    end
    
    table.insert(rejectQueue, frame)
    print("[QUEUE] Added: " .. frame.Name .. " (size: " .. #rejectQueue .. ")")
    
    if not isRejecting then
        task.spawn(processQueue)
    end
end

