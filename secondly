    sg.Name = "DeliveryCounter"; sg.ResetOnSpawn = false; sg.Parent = playerGui
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 320, 0, 100)
    frame.Position = UDim2.new(0.5, -160, 0, 10)
