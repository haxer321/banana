-- ===================== MAIN EXECUTION =====================
connectWS()

while true do
    task.wait(1)
    
    -- Keep position locked
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = TELEPORT end

    if TARGET <= 0 then continue end

    -- Tell Android to start generation
    ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Start" }))

    -- Sync Phase (Wait for 4 packages)
    print("[LOG] Waiting for " .. TARGET .. " packages...")
    while true do
        local count = 0
        for _, v in ipairs(scrollingFrame:GetChildren()) do if v:IsA("Frame") then count = count + 1 end end
        if count >= TARGET then break end
        task.wait(1)
    end

    -- Tell Android to stop generation
    ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Stop" }))

    -- Verification Phase (Wait for Server to confirm success)
    print("[LOG] Target met. Waiting for DUPE_FLAG confirmation...")
    local timeout = os.clock() + 180
    while os.clock() < timeout do
        if DUPE_FLAG == true then break end -- Server confirms delivery
        task.wait(1)
        if ws then ws:Send(HttpService:JSONEncode({ type = "get_data" })) end
    end

    -- Cleanup any overflow packages
    local frames = {}
    for _, v in ipairs(scrollingFrame:GetChildren()) do if v:IsA("Frame") then table.insert(frames, v) end end
    if #frames > TARGET then
        for i = TARGET + 1, #frames do
            fireReject(frames[i].Name)
            task.wait(0.1)
        end
    end

    -- SIGNAL SUCCESS & FINISH
    print("[DONE] Signaling Success to Android App...")
    ws:Send(HttpService:JSONEncode({ type = "complete" }))
    task.wait(2)
    player:Kick("Protocol Successful - Next Account Requested")
    break
end
