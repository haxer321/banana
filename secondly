-- Helper: Scroll frame into view
local function scrollToFrame(frame)
    if not frame or not frame.Parent then return false end
    
    -- Get the scrolling frame that contains this
    local scrollParent = frame.Parent
    while scrollParent and not scrollParent:IsA("ScrollingFrame") do
        scrollParent = scrollParent.Parent
    end
    
    if scrollParent and scrollParent:IsA("ScrollingFrame") then
        pcall(function()
            scrollParent:ScrollToChild(frame)
            task.wait(0.15) -- Wait for scroll animation
        end)
    end
    
    return true
end

-- Helper: Check if element is visible on screen
local function isElementVisible(element)
    if not element or not element.Parent then return false end
    
    -- Check if any parent is not visible
    local current = element
    while current do
        if current:IsA("GuiObject") then
            if current.Visible == false then return false end
            if current.BackgroundTransparency >= 1 and current:IsA("Frame") and #current:GetChildren() == 0 then
                -- Empty fully transparent frame - might be hidden
            end
        end
        current = current.Parent
    end
    
    return true
end

-- Helper: Get absolute center position of a GUI element
local function getElementCenter(element)
    if not element or not element.Parent then return nil, nil end
    
    local success, result = pcall(function()
        -- Calculate absolute position by walking up the hierarchy
        local offsetX = element.AbsolutePosition.X
        local offsetY = element.AbsolutePosition.Y
        local sizeX = element.AbsoluteSize.X
        local sizeY = element.AbsoluteSize.Y
        
        return offsetX + sizeX / 2, offsetY + sizeY / 2
    end)
    
    if success then
        return result
    else
        return nil, nil
    end
end

-- Get Deny button with proper path traversal
local function getDenyButton(frame)
    if not frame or not frame.Parent then return nil end
    
    -- Try multiple possible paths
    local paths = {
        {"Package", "Options", "Deny"},
        {"Options", "Deny"},
        {"Deny"},
    }
    
    for _, path in ipairs(paths) do
        local current = frame
        local found = true
        for i, name in ipairs(path) do
            current = current:FindFirstChild(name)
            if not current then
                found = false
                break
            end
        end
        if found and current and current:IsA("TextButton") and current.Parent then
            return current
        end
    end
    
    return nil
end

-- PROPER VIM CLICK - The correct way to simulate clicks in Roblox
local function vimClick(button)
    if not button or not button.Parent then
        print("[VIM] Button invalid")
        return false
    end
    
    -- Step 1: Make sure button is visible and scrolled into view
    local frame = button
    while frame and frame ~= scrollingFrame do
        if frame:IsA("Frame") then
            scrollToFrame(frame)
        end
        frame = frame.Parent
    end
    scrollToFrame(button)
    task.wait(0.1)
    
    -- Step 2: Verify button still exists and is visible
    if not button.Parent then
        print("[VIM] Button disappeared before click")
        return false
    end
    
    -- Step 3: Get the exact screen position
    local centerX, centerY = getElementCenter(button)
    if not centerX or not centerY then
        print("[VIM] Could not get button position")
        return false
    end
    
    print(string.format("[VIM] Button position: %.0f, %.0f", centerX, centerY))
    
    -- Step 4: Move mouse to button center
    pcall(function()
        VirtualInputManager:SendMouseMovementEvent(centerX, centerY, game)
    end)
    task.wait(0.05)
    
    -- Step 5: Send mouse down event
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, true, game)
    end)
    task.wait(0.02)
    
    -- Step 6: Send mouse up event
    pcall(function()
        VirtualInputManager:SendMouseButtonEvent(centerX, centerY, 0, false, game)
    end)
    task.wait(0.05)
    
    -- Step 7: Also try GuiService selection method as backup
    pcall(function()
        GuiService.SelectedObject = button
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
        task.wait(0.02)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
    end)
    task.wait(0.03)
    
    -- Step 8: Try direct event fire as final backup
    pcall(function()
        if button and button.Parent then
            button.MouseButton1Click:Fire()
        end
    end)
    
    return true
end

-- =============================================
-- ⚡ REJECTION SYSTEM - ONE AT A TIME
-- =============================================
local rejectQueue = {}
local isRejecting = false
local lastRejectComplete = 0
local REJECT_COOLDOWN = 3.0

local function doReject(frame)
    if not frame or not frame.Parent then
        print("[REJECT] Frame already gone")
        return true
    end
    
    local frameName = frame.Name
    currentAction = "Rejecting: " .. frameName
    print("[REJECT] Starting: " .. frameName)
    
    -- Get the deny button
    local denyBtn = getDenyButton(frame)
    if not denyBtn then
        print("[REJECT] ❌ No Deny button found")
        return false
    end
    
    print("[REJECT] Found Deny button: " .. denyBtn.Name)
    
    -- First click attempt
    vimClick(denyBtn)
    
    -- Wait and check if frame disappeared
    local startTime = tick()
    local maxWait = 8
    local clickCount = 1
    
    while frame.Parent and (tick() - startTime) < maxWait do
        task.wait(0.2)
        
        -- Re-click every 1.5 seconds if still there
        if frame.Parent and (tick() - startTime) > clickCount * 1.5 then
            clickCount = clickCount + 1
            denyBtn = getDenyButton(frame)
            if denyBtn then
                print("[REJECT] Re-clicking (" .. clickCount .. ")")
                vimClick(denyBtn)
            end
        end
    end
    
    local success = not frame.Parent
    if success then
        print("[REJECT] ✅ Frame removed after " .. string.format("%.1f", tick() - startTime) .. "s")
    else
        print("[REJECT] ❌ Frame still present after timeout")
    end
    
    return success
end

local function processQueue()
    if isRejecting or KILL then return end
    if #rejectQueue == 0 then return end
    
    isRejecting = true
    
    while #rejectQueue > 0 and not KILL do
        -- Find next valid frame
        local frameToReject = nil
        local frameIndex = nil
        
        for i, f in ipairs(rejectQueue) do
            if f and f.Parent then
                frameToReject = f
                frameIndex = i
                break
            end
        end
        
        if not frameToReject then
            -- Clear invalid entries
            rejectQueue = {}
            break
        end
        
        -- Remove from queue
        table.remove(rejectQueue, frameIndex)
        
        -- Wait for cooldown
        local now = tick()
        local waitTime = REJECT_COOLDOWN - (now - lastRejectComplete)
        if waitTime > 0 then
            task.wait(waitTime)
        end
        
        if KILL then break end
        
        -- Do the rejection
        doReject(frameToReject)
        lastRejectComplete = tick()
        
        -- Small delay between rejections
        task.wait(0.5)
    end
    
    isRejecting = false
    currentAction = "Idle"
end

local function enqueueReject(frame)
    if not frame or not frame.Parent then return end
    
    -- Check for duplicates
    for _, f in ipairs(rejectQueue) do
        if f == frame then
            return
        end
    end
    
    table.insert(rejectQueue, frame)
    print("[QUEUE] Added: " .. frame.Name .. " (size: " .. #rejectQueue .. ")")
    
    -- Start processing if not already
    if not isRejecting then
        task.spawn(processQueue)
    end
end

