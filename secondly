                while tick() - startT < 60 and not KILL do
                    local remaining = 60 - math.floor(tick() - startT)
                    currentAction = "Gate: overflow guard (" .. remaining .. "s)"
                    if frameCount > 4 then
                        local f = getFrames()
                        if #f > 0 then
                            rejectFrameVIM(f[math.random(1, #f)])
