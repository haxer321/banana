-- =============================================
-- WS HANDLERS — process fails INSTANTLY on data update
-- =============================================
local function connectWS()
    local ok, socket = pcall(function() return WebSocket.connect(WS_URL) end)
    if not ok or not socket then task.wait(3); return connectWS() end
    ws = socket
    ws:Send(HttpService:JSONEncode({ type = "priority_set", user = player.Name }))
    ws.OnMessage:Connect(function(msg)
        local ok2, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if ok2 and data.type == "data_update" then
            TARGET = 4
            local newFails = data.Fails or data.fails or {}
            local dupeNow = (data.Dupe == true)
            if dupeNow and not DUPE_FLAG then
                blockedUsers = {}; failTimestamps = {}
            end
            DUPE_FLAG = dupeNow
            CHECK_FLAG = (data.Check == true)
            FAILS = newFails
            -- ⚡ INSTANT processing instead of waiting for the 0.5s poll
            task.spawn(function() processFailsNow() end)
        end
    end)
    ws.OnClose:Connect(function()
        if not KILL then task.wait(2); connectWS() end
    end)
end

