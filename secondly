-- ===================== REJECT SYSTEM =====================

-- Spam a single frame until it's verified gone from UI
local function forceReject(frameName)
    print("[FORCE] Spaming reject for: " .. frameName)
    currentAction = "Rejecting overflow: " .. frameName
    while true do
        local stillExists = false
        for _, v in ipairs(scrollingFrame:GetChildren()) do
            if v.Name == frameName then stillExists = true break end
        end
        if not stillExists then break end
        
        pcall(function()
            remote:FireServer({ {rejectId, rejectStr, frameName} })
        end)
        task.wait(0.05) 
    end
    currentAction = "Idle"
end

-- Background logic for filtering fails and identifying @Unknown packages
local function processSmartFails()
    if not FAILS or #FAILS == 0 then return end
    local now = os.clock()
    local unresolved = {}

    for _, user in ipairs(FAILS) do
        local name = user:gsub("@",""):lower()
        if not blockedUsers[name] then
            unresolved[name] = true
            if not failTimestamps[name] then failTimestamps[name] = now end
        end
    end

    local unknownFrames = {}
    for _, frame in ipairs(scrollingFrame:GetChildren()) do
        if not frame:IsA("Frame") then continue end
        local sender = "unknown"
        local from = frame:FindFirstChild("Package") and frame.Package:FindFirstChild("From")
        if from then sender = from.Text:gsub("@",""):lower() end

        if unresolved[sender] then
            currentAction = "Rejecting failed sender: @" .. sender
            forceReject(frame.Name)
            blockedUsers[sender] = true
            failTimestamps[sender] = nil
            unresolved[sender] = nil
            currentAction = "Idle"
        elseif sender:find("unknown") then
            local matched = false
            for _, d in ipairs(frame:GetDescendants()) do
                if d:IsA("TextLabel") and d.Text then
                    for badUser, _ in pairs(unresolved) do
                        if d.Text:lower():find(badUser) then
                            currentAction = "Rejecting unknown matching @" .. badUser
                            forceReject(frame.Name)
                            blockedUsers[badUser] = true
                            failTimestamps[badUser] = nil
                            matched = true; break
                        end
                    end
                end
                if matched then break end
            end
            if not matched then table.insert(unknownFrames, frame) end
        end
    end

    -- 60s Fallback for Unresolved Fails
    for badUser, start in pairs(failTimestamps) do
        if now - start > 60 and #unknownFrames > 0 then
            print("[FALLBACK] Rejecting unknown for " .. badUser)
            currentAction = "Fallback reject for " .. badUser
            forceReject(unknownFrames[1].Name)
            blockedUsers[badUser] = true
            failTimestamps[badUser] = nil
            table.remove(unknownFrames, 1)
            currentAction = "Idle"
        end
    end
end

