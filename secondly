    pkgLabel.TextColor3 = Color3.fromRGB(0,255,136); pkgLabel.TextScaled = true
    pkgLabel.Font = Enum.Font.GothamBold; pkgLabel.Text = "[PKG] 0"; pkgLabel.Parent = frame
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Size = UDim2.new(1,0,0.3,0); statusLabel.Position = UDim2.new(0,0,0.4,0)
    statusLabel.BackgroundTransparency = 1; statusLabel.TextColor3 = Color3.fromRGB(139,148,158)
    statusLabel.TextScaled = true; statusLabel.Font = Enum.Font.Gotham
    statusLabel.Text = "Waiting..."; statusLabel.Parent = frame
    local dupeLabel = Instance.new("TextLabel")
