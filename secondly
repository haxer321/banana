-- =============================================
-- REJECT HELPERS (improved)
-- =============================================
local function rejectFrameByName(frameName, maxWait)
    maxWait = maxWait or 15
    local elapsed = 0
    while elapsed < maxWait do
        -- Check if frame still exists
        local found = false
        for _, frame in ipairs(scrollingFrame:GetChildren()) do
            if frame.Name == frameName then found = true; break end
        end
        if not found then return true end
        -- Send reject remote
        remote:FireServer({ {rejectId, rejectStr, frameName} })
        task.wait(0.2)
        elapsed = elapsed + 0.2
    end
    return false
end

-- Finds a frame whose "From" text matches the given user (case‑insensitive, ignoring @)
local function findFrameByUser(user)
    local userClean = user:gsub("@", ""):lower()
    for _, frame in ipairs(scrollingFrame:GetChildren()) do
        local fromBox = frame:FindFirstChild("Package") and frame.Package:FindFirstChild("From")
        if fromBox and fromBox:IsA("TextLabel") then
            local text = fromBox.Text:gsub("@", ""):lower()
            if text == userClean then
                return frame
            end
        end
    end
    return nil
end

-- Reject all packages belonging to users in FAILS
local function rejectAllFails()
    if not FAILS or #FAILS == 0 then return end
    for _, badUser in ipairs(FAILS) do
        local frame = findFrameByUser(badUser)
        if frame then
            print("[FAIL] Rejecting package from " .. badUser)
            local success = rejectFrameByName(frame.Name, 15)
            if success then
                print("[FAIL] Rejected " .. badUser)
            else
                print("[FAIL] Failed to reject " .. badUser .. " (timeout)")
            end
        end
    end
end

-- =============================================
-- WS CONNECTION + MESSAGE HANDLER
-- =============================================
local function connectWS()
    print("[WSS] Syncing with Android...")
    local ok, socket = pcall(function() return WebSocket.connect(WS_URL) end)
    if not ok or not socket then
        task.wait(5)
        return connectWS()
    end
    ws = socket

    -- Send priority claim (non‑blocking)
    ws:Send(HttpService:JSONEncode({ type = "priority_set", user = player.Name }))
    print("[WSS] Sent priority claim for " .. player.Name)

    local priorityConfirmed = false
    ws.OnMessage:Connect(function(msg)
        local ok2, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok2 then return end

        -- Implicit ack: any message with our user
        if data.user == player.Name then
            if not priorityConfirmed then
                priorityConfirmed = true
                print("[WSS] Priority implicitly confirmed")
            end
        end

        -- Process data updates
        if data.type == "data_update" then
            TARGET    = tonumber(data.target) or 0
            DUPE_FLAG = (data.Dupe == true)
            CHECK_FLAG= (data.Check == true)
            FAILS     = data.Fails or data.fails or {}
            print("[WSS] Target=" .. TARGET .. " Dupe=" .. tostring(DUPE_FLAG) .. " Check=" .. tostring(CHECK_FLAG) .. " Fails=" .. #FAILS)

            -- ***** IMMEDIATE FAIL REJECTION *****
            task.spawn(function()
                rejectAllFails()
            end)
        end
    end)

    -- Wait a short time for initial confirmation
    local timeout = os.clock() + 5
    while os.clock() < timeout and not priorityConfirmed do
        task.wait(0.1)
    end
    if not priorityConfirmed then
        print("[WSS] No confirmation within 5s, proceeding anyway...")
    end

    ws.OnClose:Connect(function()
        print("[WSS] Connection closed. Reconnecting in 2s...")
        task.wait(2)
        connectWS()
    end)
end

-- =============================================
-- HEARTBEAT (IMMEDIATE START)
-- =============================================
task.spawn(function()
    while not KILL do
        if ws then
            local ok, _ = pcall(function()
                ws:Send(HttpService:JSONEncode({ type = "heartbeat", user = player.Name }))
                ws:Send(HttpService:JSONEncode({ type = "get_data" }))
            end)
            if not ok then
                print("[WSS] Heartbeat send failed (expected during disconnect)")
            end
        end
        task.wait(10)
    end
end)

connectWS()

-- =============================================
-- MAIN CYCLE
-- =============================================
while not KILL do
    task.wait(2)

    -- Keep teleporting
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = TELEPORT end

    if TARGET <= 0 then
        updateGui("Waiting...")
        continue
    end

    updateGui("Target: " .. TARGET .. " pkgs")

    -- Signal start
    ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Start" }))

    -- Collect until target met
    while not KILL do
        local count = 0
        for _, v in ipairs(scrollingFrame:GetChildren()) do if v:IsA("Frame") then count = count + 1 end end
        updateGui(count .. "/" .. TARGET .. " pkgs")
        if count >= TARGET then break end
        task.wait(0.5)
    end

    if KILL then break end

    ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Stop" }))

    -- Wait for server to set Check=false
    local timeout = os.clock() + 180
    print("[WSS] Target met. Waiting for Server Confirmation (Check=false)...")
    while os.clock() < timeout do
        if CHECK_FLAG == false then break end
        task.wait(1)
        if ws then ws:Send(HttpService:JSONEncode({ type = "get_data" })) end
        updateGui()
    end

    if KILL then break end

    -- =============================================
    -- REJECT EXCESS PACKAGES (if any)
    -- =============================================
    local frames = {}
    for _, v in ipairs(scrollingFrame:GetChildren()) do
        if v:IsA("Frame") then table.insert(frames, v) end
    end
    if #frames > TARGET then
        print("[WSS] Rejecting " .. (#frames - TARGET) .. " excess packages")
        for i = TARGET + 1, #frames do
            if KILL then break end
            rejectFrameByName(frames[i].Name, 15)
            task.wait(0.2)
        end
    end

    -- Final sync
    print("[WSS] Sync Complete. Signaling Success...")
    ws:Send(HttpService:JSONEncode({ type = "complete" }))
    task.wait(2)

    local finalCount = 0
    for _, v in ipairs(scrollingFrame:GetChildren()) do if v:IsA("Frame") then finalCount = finalCount + 1 end end
    local totalM = (finalCount * PACKAGE_GEMS) / 1000000
    updateGui("Done: " .. totalM .. "M")
    player:Kick("Success: " .. totalM .. "M gems via WSS")
    break
end

print("[WSS] Script ended.")
