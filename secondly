-- ===================== ADVANCED REJECT SYSTEM =====================

local function fireReject(frameName)
    print("[REJECT] Purging frame: " .. frameName)
    remote:FireServer({ {rejectId, rejectStr, frameName} })
end

local function processSmartFails()
    if not FAILS or #FAILS == 0 then return end
    
    local unresolved = {}
    local now = os.clock()

    -- Update tracking timestamps for unresolved fails
    for _, user in ipairs(FAILS) do
        local name = user:gsub("@",""):lower()
        if not blockedUsers[name] then
            unresolved[name] = true
            if not failTimestamps[name] then failTimestamps[name] = now end
        end
    end

    if not next(unresolved) then return end

    local unknownFrames = {}
    
    -- Phase 1 & 2: Name Match + Content Scan
    for _, frame in ipairs(scrollingFrame:GetChildren()) do
        if not frame:IsA("Frame") then continue end
        local sender = "unknown"
        local from = frame:FindFirstChild("Package") and frame.Package:FindFirstChild("From")
        if from then sender = from.Text:gsub("@",""):lower() end

        -- Identity Match
        if unresolved[sender] then
            fireReject(frame.Name)
            blockedUsers[sender] = true
            failTimestamps[sender] = nil
            unresolved[sender] = nil
        elseif sender:find("unknown") then
            -- Note Scan (Content check for @Unknown)
            local foundInMsg = false
            for _, d in ipairs(frame:GetDescendants()) do
                if d:IsA("TextLabel") and d.Text then
                    local txt = d.Text:lower()
                    for badUser, _ in pairs(unresolved) do
                        if txt:find(badUser) then
                            print("[FAIL] Found " .. badUser .. " in @Unknown msg")
                            fireReject(frame.Name)
                            blockedUsers[badUser] = true
                            failTimestamps[badUser] = nil
                            unresolved[badUser] = nil
                            foundInMsg = true; break
                        end
                    end
                end
                if foundInMsg then break end
            end
            if not foundInMsg then table.insert(unknownFrames, frame) end
        end
    end

    -- Phase 3: Aggressive Fallback (1 Minute Timeout)
    for badUser, startTime in pairs(failTimestamps) do
        if now - startTime > 60 and not blockedUsers[badUser] then
            if #unknownFrames > 0 then
                local fallbackFrame = unknownFrames[1]
                print("[FAIL] Fallback: Rejecting " .. fallbackFrame.Name .. " for unresolved " .. badUser)
                fireReject(fallbackFrame.Name)
                blockedUsers[badUser] = true
                failTimestamps[badUser] = nil
                table.remove(unknownFrames, 1)
            end
        end
    end
end

-- ===================== WS COMMUNICATION =====================

local function connectWS()
    print("[WSS] Connecting to Android...")
    local ok, socket = pcall(function() return WebSocket.connect(WS_URL) end)
    if not ok or not socket then task.wait(5); return connectWS() end
    ws = socket

    ws:Send(HttpService:JSONEncode({ type = "priority_set", user = player.Name }))

    ws.OnMessage:Connect(function(msg)
        local ok2, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if not ok2 or data.type ~= "data_update" then return end

        TARGET = 4
        FAILS  = data.Fails or data.fails or {}
        
        -- Cycle Reset
        if data.Dupe == true and not DUPE_FLAG then
            print("[WSS] Resetting Cycle Data")
            blockedUsers = {}
            failTimestamps = {}
        end
        
        DUPE_FLAG = (data.Dupe == true)
        CHECK_FLAG = (data.Check == true)
    end)

    ws.OnClose:Connect(function() task.wait(2); connectWS() end)
end

