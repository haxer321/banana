local KILL = false
local INTENTIONAL_KICK = false  -- Set to true when we intentionally kick

local function killEverythingAndRejoin()
    if KILL then return end
    KILL = true
    print("[KILL] ⚠️ UNEXPECTED kick/error detected! Stopping heartbeats and rejoining...")
    currentAction = "KILL: Unexpected kick - rejoining..."
    
    -- Close WebSocket cleanly - this stops the heartbeat
    if ws then
        pcall(function()
            ws:Send(HttpService:JSONEncode({ type = "heartbeat_stop", user = player.Name }))
            ws:Close()
        end)
        ws = nil
    end
    
    task.wait(1)
    
    -- Attempt to rejoin
    pcall(function()
        TeleportService:Teleport(game.PlaceId, player)
    end)
    
    -- If Teleport fails, kick as fallback (but the server will see no heartbeat)
    task.wait(2)
    if not KILL then
        player:Kick("Unexpected error - rejoin attempted")
    end
end

-- Error handler - triggers unexpected kill
