                    while not KILL and #FAILS > 0 do
                        if frameCount > 4 then
                            local f = getFrames()
                            if #f > 0 then enqueueReject(f[math.random(1, #f)]) end
                        end
                        currentAction = "Waiting fails (" .. #FAILS .. ")"
                        task.wait(0.3)
                    end
                    if KILL then return end

                    -- Overflow guard
                    local startT = tick()
                    while tick() - startT < 60 and not KILL do
                        local remaining = 60 - math.floor(tick() - startT)
                        currentAction = "Guard (" .. remaining .. "s)"
                        if frameCount > 4 then
                            local f = getFrames()
                            if #f > 0 then enqueueReject(f[math.random(1, #f)]) end
                        end
                        task.wait(0.3)
                    end
                    break
                end
            end
        end
        if KILL then return end

        -- Phase 3: Complete
        currentAction = "Completing..."
        if ws then ws:Send(HttpService:JSONEncode({ type = "complete" })) end
        task.wait(1)

        currentAction = "✅ Done - kicking"
        INTENTIONAL_KICK = true
        if ws then
            ws:Send(HttpService:JSONEncode({ type = "heartbeat_stop", user = player.Name }))
            ws:Close()
            ws = nil
        end
        task.wait(0.5)
        player:Kick("✅ Success - 4/4 Packages")
    end)
    
    if KILL then break end
end
