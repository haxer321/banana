while not KILL do
    task.wait(0.5)  -- was 2
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = TELEPORT
        if not initFired then
            currentAction = "Initializing post office"
            pcall(function() remote:FireServer({ { initIdentifier } }) end)
            initFired = true
        end
    end

    if TARGET <= 0 then continue end
    if KILL then break end

    -- Phase 1: Accumulation (tight loop)
    currentAction = "Collecting packages: 0/" .. TARGET
    while not KILL do
        if frameCount >= TARGET then break end
        currentAction = "Collecting packages: " .. frameCount .. "/" .. TARGET
        if ws then
            pcall(function() ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Start" })) end)
        end
        task.wait(0.3)  -- was 1
    end
    if KILL then break end

    currentAction = "Collected " .. TARGET .. ", stopping generation"
    if ws then
        pcall(function() ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Stop" })) end)
    end

    -- Phase 2: GATE
    currentAction = "Gate: awaiting dupe flag"
    while not KILL do
        if ws then ws:Send(HttpService:JSONEncode({ type = "get_data" })) end
        task.wait(0.3)  -- was 1

        if DUPE_FLAG == true then
            if frameCount < 4 then
                currentAction = "Gate: count <4, restarting"
                if ws then ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Start" })) end
            elseif frameCount > 4 then
                local frames = getFrames()
                forceReject(frames[math.random(1, #frames)].Name)
                currentAction = "Gate: awaiting dupe flag"
            else
                -- 4 confirmed, wait for FAILS to clear
                currentAction = "Waiting for FAILS to clear... (#" .. #FAILS .. ")"
                while not KILL and #FAILS > 0 do
                    if frameCount > 4 then
                        local f = getFrames()
                        forceReject(f[math.random(1, #f)].Name)
                    end
                    currentAction = "Waiting for FAILS to clear... (#" .. #FAILS .. ")"
                    task.wait(0.3)  -- was 1
                end
                if KILL then break end

                -- 60s overflow guard
                local startT = tick()
                while tick() - startT < 60 and not KILL do
                    local remaining = 60 - math.floor(tick() - startT)
                    currentAction = "Gate: overflow guard (" .. remaining .. "s)"
                    if frameCount > 4 then
                        local f = getFrames()
                        forceReject(f[math.random(1, #f)].Name)
                    end
                    task.wait(0.3)  -- was 0.5
                end
                break
            end
        end
    end
    if KILL then break end

    -- Phase 3: Finalize
    currentAction = "Signaling complete..."
    if ws then ws:Send(HttpService:JSONEncode({ type = "complete" })) end
    task.wait(1)  -- was 2

    currentAction = "✅ Intentional completion - kicking"
    INTENTIONAL_KICK = true
    if ws then
        pcall(function()
            ws:Send(HttpService:JSONEncode({ type = "heartbeat_stop", user = player.Name }))
            ws:Close()
        end)
        ws = nil
    end
    task.wait(0.5)
    player:Kick("✅ Success - 4/4 Packages Verified")
    break
end
