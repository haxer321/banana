                print("[GATE] ✅ 4/4 confirmed. Starting 60-second overflow guard...")
                local startTime = tick()
                while tick() - startTime < 60 and not KILL do
                    local remaining = 60 - math.floor(tick() - startTime)
                    currentAction = "Gate: overflow guard (" .. remaining .. "s left)"
                    task.wait(0.5)
                    local currentFrames = {}
                    for _, v in ipairs(scrollingFrame:GetChildren()) do
                        if v:IsA("Frame") then table.insert(currentFrames, v) end
                    end
                    if #currentFrames > 4 then
