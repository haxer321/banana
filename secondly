-- =============================================
-- PRIORITY AUTH — soft takeover, never blocks loading
-- =============================================
if not game:IsLoaded() then game.Loaded:Wait() end

local Players         = game:GetService("Players")
local HttpService     = game:GetService("HttpService")
local player          = Players.LocalPlayer
local SERVER_IP       = "http://localhost:8080"
local requestFunc     = syn and syn.request or http and http.request or request

local function getPriority()
    local ok, res = pcall(function()
        return requestFunc({ Url = SERVER_IP .. "/priority", Method = "GET" })
    end)
    if ok and res and res.Body then
        local ok2, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if ok2 and data then return data end
    end
    return nil
end

local priority = getPriority()
if not priority or priority.sendto ~= player.Name then
    -- Attempt to take over priority
    pcall(function()
        requestFunc({
            Url = SERVER_IP .. "/priority/set",
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode({ username = player.Name })
        })
    end)
    task.wait(1)
    priority = getPriority()
    if not priority or priority.sendto ~= player.Name then
        print("[AUTH] Could not set priority — continuing anyway (heartbeat will retry)")
    else
        print("[AUTH] Priority confirmed — loaded script")
    end
else
    print("[AUTH] Priority already confirmed — loaded script")
end

-- =============================================
-- CONFIGURATION VARIABLES
-- =============================================
local PACKAGE_GEMS       = 10000000 -- 10 million gems per package
local TELEPORT_CFRAME    = CFrame.new(-460, 244, -67)
local KILL_ON_ERROR      = true

-- =============================================
-- 0. INITIALIZATION
-- =============================================
repeat task.wait() until game:IsLoaded()

local ReplicatedStorage   = game:GetService("ReplicatedStorage")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService          = game:GetService("GuiService")

-- =============================================
-- KILL SWITCH
-- =============================================
local KILL = false
local STOP = false
local function killEverything()
    if KILL then return end
    KILL = true
    print("[KILL] Stopping everything...")
    local pGui = player:FindFirstChild("PlayerGui")
    if pGui then
        local counter = pGui:FindFirstChild("DeliveryCounter")
        if counter then counter:Destroy() end
    end
end

if KILL_ON_ERROR then
    GuiService.ErrorMessageChanged:Connect(function()
        if GuiService.ErrorMessage and GuiService.ErrorMessage ~= "" then
            killEverything()
        end
    end)
    Players.PlayerRemoving:Connect(function(p)
        if p == player then killEverything() end
    end)
end

local char = player.Character or player.CharacterAdded:Wait()
repeat task.wait() until char:FindFirstChild("HumanoidRootPart")
task.wait(5)

task.spawn(function()
    while not KILL do
        local c = player.Character or player.CharacterAdded:Wait()
        local hrp = c:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CFrame = TELEPORT_CFRAME break end
        task.wait(1)
    end
end)

local playerGui  = player:WaitForChild("PlayerGui")
local loadingGui = playerGui:FindFirstChild("LoadingGui")
if loadingGui then
    repeat task.wait(0.05) until not loadingGui.Parent
    task.wait(5)
end
print("[LOAD] Game fully loaded")

-- =============================================
-- REMOTE + IDs
-- =============================================
local remote = ReplicatedStorage:WaitForChild("NetworkingContainer"):WaitForChild("DataRemote")

local rejectIdValue = ReplicatedStorage:WaitForChild("IdentifiersContainer"):WaitForChild(
    "RF_9ff1f197bac1aed0e111d8b6c30732ea1a98d77594aa860e7ec9dae51fc194e5_S"
).Value
local rejectStaticStr = "\175+\190\168z\137N\150\168}\161C\201\240\178\204"

local scrollingFrame = playerGui:WaitForChild("Lobby")
    :WaitForChild("PostOffice"):WaitForChild("Menus")
    :WaitForChild("ReceivePackages"):WaitForChild("ScrollingFrame")
local menusGui      = playerGui.Lobby.PostOffice.Menus

-- =============================================
-- STATE
-- =============================================
local myUsername       = player.Name
local rejectedUsers    = {}

task.spawn(function()
    local lobby = playerGui:WaitForChild("Lobby", 30)
    if not lobby then return end
    local postOffice = lobby:FindFirstChild("PostOffice")
    if not postOffice then return end
    postOffice.AncestryChanged:Connect(function(_, parent)
        if not parent and not STOP and not KILL then
            STOP = true
        end
    end)
end)

-- =============================================
-- HTTP HELPERS
-- =============================================
if not requestFunc then error("No request function") end

local function safeRequest(options)
    if KILL then return nil end
    local ok, res = pcall(function() return requestFunc(options) end)
    return ok and res or nil
end

local function getData()
    local res = safeRequest({ Url = SERVER_IP .. "/data", Method = "GET" })
    if res and res.Body then
        local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if ok then return data end
    end
    return nil
end

local function getCurrentTarget()
    local res = safeRequest({ Url = SERVER_IP .. "/current-target", Method = "GET" })
    if res and res.Body then
        local target = tonumber(res.Body)
        return target or 0
    end
    return 0
end

local function setServerState(s)
    if KILL then return end
    safeRequest({
        Url     = SERVER_IP .. "/data",
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = HttpService:JSONEncode({ State = tostring(s) })
    })
    print("[STATE] -> " .. s)
end

local function signalComplete()
    if KILL then return end
    print("[COMPLETE] Signaling Android App to logout and switch...")
    safeRequest({ Url = SERVER_IP .. "/Complete", Method = "GET" })
end

-- =============================================
-- GEMS & PACKAGES
-- =============================================
local function countPackages()
    if KILL then return 0 end
    local count = 0
    for _, child in ipairs(scrollingFrame:GetChildren()) do
        if child:IsA("Frame") then count += 1 end
    end
    return count
end

local guiPkgLabel, guiStatusLabel

-- =============================================
-- REJECT SYSTEM
-- =============================================
local function unblockAllUsers()
    if KILL then return end
    for u in pairs(rejectedUsers) do rejectedUsers[u] = nil end
end

local function rejectFrameByName(frameName, maxWait)
    if KILL then return false end
    maxWait = maxWait or 15
    local elapsed = 0
    while elapsed < maxWait do
        local stillThere = false
        for _, frame in ipairs(scrollingFrame:GetChildren()) do
            if frame.Name == frameName then stillThere = true break end
        end
        if not stillThere then return true end
        remote:FireServer(unpack({ { { rejectIdValue, rejectStaticStr, frameName } } }))
        task.wait(0.1); elapsed += 0.1
    end
    return false
end

local function processAllFailedUsers(failsList)
    if KILL or type(failsList) ~= "table" then return end
    for _, user in ipairs(failsList) do
        if not rejectedUsers[user] then
            for _, frame in ipairs(scrollingFrame:GetChildren()) do
                if frame:IsA("Frame") then
                    local fromBox = frame:FindFirstChild("Package") and frame.Package:FindFirstChild("From")
                    if fromBox and fromBox:IsA("TextBox") and fromBox.Text:gsub("@","") == user then
                        if rejectFrameByName(frame.Name, 15) then rejectedUsers[user] = true end
                        break
                    end
                end
            end
        end
    end
end

