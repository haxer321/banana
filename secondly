local function processSmartFails()
    if KILL or not FAILS or #FAILS == 0 then return end
    local now = os.clock()
    local unresolved = {}

    for _, user in ipairs(FAILS) do
        local name = user:gsub("@",""):lower()
        if name ~= "" and not blockedUsers[name] then
            unresolved[name] = true
            if not failTimestamps[name] then failTimestamps[name] = now end
        end
    end

    if next(unresolved) == nil then return end

    local unknownFrames = {}
    for _, frame in ipairs(scrollingFrame:GetChildren()) do
        if not frame:IsA("Frame") then continue end

        local sender = getFrameSender(frame)
        local message = getFrameMessage(frame)
        local senderLower = (sender or "unknown"):gsub("@",""):lower()
        local messageTrimmed = message:gsub("%s+", "")

        -- 1) CORRUPT PACKAGE: @Unknown with empty message
        if senderLower == "unknown" and messageTrimmed == "" then
            print("[CORRUPT] Rejected corrupt package from @Unknown with empty message")
            currentAction = "Rejecting corrupt @Unknown with empty message"
            forceReject(frame.Name)
            currentAction = "Idle"
            continue
        end

        -- 2) DIRECT SENDER MATCH
        if unresolved[senderLower] then
            currentAction = "Rejecting failed sender: @" .. senderLower
            forceReject(frame.Name)
            blockedUsers[senderLower] = true
            failTimestamps[senderLower] = nil
            unresolved[senderLower] = nil
            currentAction = "Idle"
            continue
        end

        -- 3) SENDER TEXT CONTAINS FAIL NAME (original fallback)
        local matched = findFailsInText(sender, unresolved)
        if matched then
            currentAction = "Rejecting via sender scan: @" .. matched
            forceReject(frame.Name)
            blockedUsers[matched] = true
            failTimestamps[matched] = nil
            unresolved[matched] = nil
            currentAction = "Idle"
            continue
        end

        -- 4) **NEW**: @Unknown sender BUT message contains a fail name
        if senderLower == "unknown" then
            local matchedMsg = findFailsInText(message, unresolved)
            if matchedMsg then
                print("[MSG] Rejecting @Unknown package whose message contains fail: " .. matchedMsg)
                currentAction = "Rejecting via message scan (Unknown sender): @" .. matchedMsg
                forceReject(frame.Name)
                blockedUsers[matchedMsg] = true
                failTimestamps[matchedMsg] = nil
                unresolved[matchedMsg] = nil
                currentAction = "Idle"
                continue
            end
        end

        -- 5) Otherwise, if sender contains "unknown", add to fallback list
        if senderLower:find("unknown") then
            table.insert(unknownFrames, frame)
        end
    end

    -- 60s Fallback for Unresolved Fails
    for badUser, start in pairs(failTimestamps) do
        if now - start > 60 and #unknownFrames > 0 then
            print("[FALLBACK] Rejecting unknown for " .. badUser)
            currentAction = "Fallback reject for " .. badUser
            forceReject(unknownFrames[1].Name)
            blockedUsers[badUser] = true
            failTimestamps[badUser] = nil
            table.remove(unknownFrames, 1)
            currentAction = "Idle"
        end
    end
end
