-- ========== Reject spam helper ==========
local function rejectFrameByName(frameName, maxWait)
    maxWait = maxWait or 15
    local elapsed = 0
    while elapsed < maxWait do
        local stillThere = false
        for _, frame in ipairs(scrollingFrame:GetChildren()) do
            if frame.Name == frameName then stillThere = true break end
        end
        if not stillThere then return true end
        remote:FireServer({ {rejectId, rejectStr, frameName} })
        task.wait(0.1); elapsed += 0.1
    end
    return false
end

-- ===================== WS HANDLERS =====================
local function connectWS()
    print("[WSS] Syncing with Android...")
    local ok, socket = pcall(function() return WebSocket.connect(WS_URL) end)
    if not ok or not socket then
        task.wait(5)
        return connectWS()
    end
    ws = socket

    -- Claim priority
    ws:Send(HttpService:JSONEncode({ type = "priority_set", user = player.Name }))

    ws.OnMessage:Connect(function(msg)
        local ok2, data = pcall(function() return HttpService:JSONDecode(msg) end)
        if ok2 and data.type == "data_update" then
            TARGET = tonumber(data.target) or 0
            FAILS  = data.Fails or data.fails or {}
            DUPE_FLAG = data.Dupe == true
            CHECK_FLAG = data.Check == true
        end
    end)

    ws.OnClose:Connect(function()
        task.wait(2)
        connectWS()
    end)
end

