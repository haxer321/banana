task.spawn(function()
    local url = SERVER_IP .. "/priority-heartbeat?user=" .. myUsername
    while not STOP and not KILL do
        safeRequest({ Url = url, Method = "GET" })
        task.wait(10)
    end
end)

-- =============================================
-- MAIN DUPE & CLEANUP FLOW
-- =============================================
print("[MAIN] Starting...")
updateGui("[ZZZ] Waiting for target")

while not STOP and not KILL do
    task.wait(2)

    local target = getCurrentTarget()

    if not target or target <= 0 then
        updateGui("[ZZZ] No target")
        setServerState("Stop")
        continue
    end

    updateGui("[NEW] Target: " .. target .. " pkgs")
    print("[MAIN] Target received: " .. target .. " packages")

    -- Start Generation
    setServerState("Start")
    task.wait(0.5)

    -- Monitor scrolling frame for packages
    while not STOP and not KILL do
        local currentCount = countPackages()
        updateGui("[SYNC] " .. currentCount .. "/" .. target .. " pkgs")
        if currentCount >= target then
            break
        end
        task.wait(0.5)
    end

    if STOP or KILL then 
        setServerState("Stop")
        continue 
    end

    -- STOP GENERATION IMMEDIATELY
    setServerState("Stop")
    updateGui("[STOP] Target reached, stopping gen...")
    task.wait(0.5)

    -- PRECISION CLEANUP
    local currentCount = countPackages()
    if currentCount > target then
        updateGui("[CLEANUP] Rejecting " .. (currentCount - target) .. " extra pkgs...")
        print("[CLEANUP] Overflow detected. Rejecting " .. (currentCount - target) .. " packages back to mail.")
        
        local frames = {}
        for _, child in ipairs(scrollingFrame:GetChildren()) do
            if child:IsA("Frame") then table.insert(frames, child) end
        end
        
        -- Keep exactly `target` packages, reject the rest
        for i = target + 1, #frames do
            if KILL or STOP then break end
            rejectFrameByName(frames[i].Name, 15)
            task.wait(0.1)
        end
    end

    if STOP or KILL then continue end

    -- FINALIZATION
    local finalCount = countPackages()
    local totalGems = finalCount * PACKAGE_GEMS
    local totalM = totalGems / 1000000
    
    updateGui("[DONE] " .. totalM .. "M gems total!")
    print("[MAIN] Cleanup complete. " .. finalCount .. " packages kept in mail.")
    
    -- Signal completion to Android App
    signalComplete()
    
    task.wait(1)
    
    -- Kick the player cleanly
    pcall(function()
        player:Kick("Done : " .. totalM .. " M gems total!")
    end)
    
    break
end

print("[SCRIPT] Delivery script ended")
