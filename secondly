                        currentAction = "Gate: rejecting overflow in guard"
                        forceReject(currentFrames[math.random(1, #currentFrames)].Name)
                        currentAction = "Gate: overflow guard (" .. remaining .. "s left)"
                    end
                end
                -- after 60 seconds with no overflow (or cleaned), exit
                break
