                        local f = getFrames()
                        if #f > 0 then
                            rejectFrameVIM(f[math.random(1, #f)])
                        end
                    end
                    currentAction = "Waiting for FAILS to clear... (#" .. #FAILS .. ")"
                    task.wait(0.3)
