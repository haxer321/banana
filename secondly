-- =============================================
-- ⚡ FAST FRAME CACHE (event-driven count)
-- =============================================
local frameCache = {}        -- [frameName] = frame
local frameCount = 0

local function rebuildCache()
    frameCache = {}
    frameCount = 0
    for _, v in ipairs(scrollingFrame:GetChildren()) do
        if v:IsA("Frame") then
            frameCache[v.Name] = v
            frameCount = frameCount + 1
        end
    end
end
rebuildCache()

local function getFrames()
    local out = {}
    for _, f in pairs(frameCache) do table.insert(out, f) end
    return out
end

scrollingFrame.ChildAdded:Connect(function(c)
    if c:IsA("Frame") then
        frameCache[c.Name] = c
        frameCount = frameCount + 1
    end
end)
scrollingFrame.ChildRemoved:Connect(function(c)
    if c:IsA("Frame") and frameCache[c.Name] then
        frameCache[c.Name] = nil
        frameCount = frameCount - 1
