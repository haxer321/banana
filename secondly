-- 📡 ANDROID AUTOMATOR — OPTIMIZED LUA
-- =============================================
if not game:IsLoaded() then game.Loaded:Wait() end

local Players         = game:GetService("Players")
local HttpService     = game:GetService("HttpService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local GuiService      = game:GetService("GuiService")
local RunService      = game:GetService("RunService")

local player          = Players.LocalPlayer
local SERVER_IP       = "http://localhost:8080"
local requestFunc     = syn and syn.request or http and http.request or request

-- CONFIG
local PACKAGE_GEMS       = 10000000 -- 10M Units
local TELEPORT_CFRAME    = CFrame.new(-460, 244, -67)

-- ===================== HTTP HELPERS =====================
local function safeRequest(options)
    local ok, res = pcall(function() return requestFunc(options) end)
    if not ok then print("[ERROR] Request failed: " .. tostring(res)) end
    return ok and res or nil
end

local function getPriority()
    local res = safeRequest({ Url = SERVER_IP .. "/priority", Method = "GET" })
    if res and res.Body then
        local ok, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
        if ok then return data end
    end
    return nil
end

local function getCurrentTarget()
    local res = safeRequest({ Url = SERVER_IP .. "/current-target", Method = "GET" })
    if res and res.Body then return tonumber(res.Body) or 0 end
    return 0
end

local function setServerState(s)
    safeRequest({
        Url     = SERVER_IP .. "/data",
        Method  = "POST",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = HttpService:JSONEncode({ State = tostring(s) })
    })
    print("[DEBUG] Server State -> " .. s)
end

-- ===================== HEARTBEAT & PRIORITY =====================
-- This runs in background to tell Android app to skip Tap Test
task.spawn(function()
    while true do
        local p = getPriority()
        -- FIX: Use 'sendto' to match Android App
        if not p or p.sendto ~= player.Name then
            print("[AUTH] Requesting priority for: " .. player.Name)
            safeRequest({
                Url = SERVER_IP .. "/priority/set",
                Method = "POST",
                Headers = { ["Content-Type"] = "application/json" },
                Body = HttpService:JSONEncode({ username = player.Name })
            })
        end
        -- Android app skips tap test if this is received within 30s
        safeRequest({ Url = SERVER_IP .. "/priority-heartbeat?user=" .. player.Name, Method = "GET" })
        task.wait(10)
    end
end)

-- ===================== ELEMENTS =====================
local playerGui      = player:WaitForChild("PlayerGui")
local scrollingFrame = playerGui:WaitForChild("Lobby"):WaitForChild("PostOffice"):WaitForChild("Menus"):WaitForChild("ReceivePackages"):WaitForChild("ScrollingFrame")
local remote         = ReplicatedStorage:WaitForChild("NetworkingContainer"):WaitForChild("DataRemote")
local rejectIdValue  = ReplicatedStorage:WaitForChild("IdentifiersContainer"):WaitForChild("RF_9ff1f197bac1aed0e111d8b6c30732ea1a98d77594aa860e7ec9dae51fc194e5_S").Value
local rejectStatic   = "\175+\190\168z\137N\150\168}\161C\201\240\178\204"

local function countPackages()
    local count = 0
    for _, child in ipairs(scrollingFrame:GetChildren()) do
        if child:IsA("Frame") then count += 1 end
    end
    return count
end

-- ===================== MAIN CYCLE =====================
RunService:Set3dRenderingEnabled(false)
print("[LOAD] Script active. Waiting for teleport...")

while true do
    task.wait(2)
    -- Teleport fallback
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = TELEPORT_CFRAME end

    local target = getCurrentTarget()
    if target <= 0 then
        print("[DEBUG] Waiting for order target...")
        setServerState("Stop")
        continue
    end

    print("[DEBUG] Target Found: " .. target)
    setServerState("Start")

    -- Wait Phase
    while countPackages() < target do
        task.wait(1)
    end

    setServerState("Stop")
    print("[DEBUG] Target Reached. Cleaning...")

    -- Cleanup
    local frames = {}
    for _, child in ipairs(scrollingFrame:GetChildren()) do
        if child:IsA("Frame") then table.insert(frames, child) end
    end

    if #frames > target then
        for i = target + 1, #frames do
            remote:FireServer(unpack({ { { rejectIdValue, rejectStatic, frames[i].Name } } }))
            task.wait(0.1)
        end
    end

    -- Signal completion (Android app will logout)
    print("[DONE] Signaling completion...")
    safeRequest({ Url = SERVER_IP .. "/Complete", Method = "GET" })
    
    task.wait(2)
    player:Kick("Protocol Complete")
    break
end
