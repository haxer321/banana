    -- Stop generation once count is met
    ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Stop" }))

    -- Phase 2: FINAL GATE (Wait for server confirmation + overflow guard)
    print("[GATE] Waiting for DUPE_FLAG == true...")
    currentAction = "Gate: awaiting dupe flag"
    while true do
        if ws then ws:Send(HttpService:JSONEncode({ type = "get_data" })) end
        task.wait(1)

        if DUPE_FLAG == true then
            local frames = {}
            for _, v in ipairs(scrollingFrame:GetChildren()) do
                if v:IsA("Frame") then table.insert(frames, v) end
            end

            if #frames < 4 then
                print("[GATE] Count dropped below 4! Restarting generation...")
                currentAction = "Gate: count <4, restarting generation"
                ws:Send(HttpService:JSONEncode({ type = "set_state", value = "Start" }))
