-- =====================================================
-- 🎯 VIM-BASED REJECTION METHOD (Single Reject + Cooldown)
-- =====================================================

-- Make ReceivePackages GUI visible
local receivePackagesGui = playerGui:WaitForChild("Lobby"):WaitForChild("PostOffice"):WaitForChild("Menus"):WaitForChild("ReceivePackages")
receivePackagesGui.Visible = true

local lastRejectTime = 0
local REJECT_COOLDOWN = 5  -- 5 second cooldown per rejection

-- =====================================================
-- Find Deny button for a given frame
-- =====================================================
local function getDenyButton(frame)
    if not frame or not frame:IsA("Frame") then return nil end
    local pkg = frame:FindFirstChild("Package")
    if not pkg then return nil end
    local options = pkg:FindFirstChild("Options")
    if not options then return nil end
    local denyBtn = options:FindFirstChild("Deny")
    if not denyBtn or not denyBtn:IsA("TextButton") then return nil end
    return denyBtn
end

-- =====================================================
-- Reject a frame using VIM (click Deny button)
-- =====================================================
local function rejectFrameVIM(frame)
    if not frame or not frame.Parent then return false end
    
    -- Check cooldown
    local now = tick()
    if now - lastRejectTime < REJECT_COOLDOWN then
        print(string.format("[REJECT] Cooldown active (%.1fs remaining)", REJECT_COOLDOWN - (now - lastRejectTime)))
        return false
    end
    
    -- Get Deny button
    local denyButton = getDenyButton(frame)
    if not denyButton then
        print("[REJECT] Deny button not found for frame: " .. frame.Name)
        return false
    end
    
    currentAction = "Clicking Deny on " .. frame.Name
    print("[REJECT] Clicking Deny for frame: " .. frame.Name)
    
    -- Select the button
    GuiService.SelectedObject = denyButton
    task.wait(0.05)
    
    -- Send Return key press + release (keyboard activation)
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
    
    -- Also send ButtonA for gamepad compatibility
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.ButtonA, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.ButtonA, false, game)
    
    print("[REJECT] Waiting for frame to disappear...")
    
    -- Wait for frame to disappear (check every 0.1s)
    local timeoutStart = tick()
    while frame.Parent and tick() - timeoutStart < 10 do
        task.wait(0.1)
    end
    
    if not frame.Parent then
        print("[REJECT] ✅ Frame successfully removed")
        lastRejectTime = tick()
        return true
    else
        print("[REJECT] ❌ Frame still present after timeout")
        return false
    end
end

-- =====================================================
-- Process fails with VIM rejection (one at a time with cooldown)
-- =====================================================
local function processFailsVIM()
    if KILL or #FAILS == 0 then return end
    
    local now = os.clock()
    local unresolved = {}
    
    for _, user in ipairs(FAILS) do
        local name = user:gsub("@",""):lower()
        if name ~= "" and not blockedUsers[name] then
            unresolved[name] = true
            if not failTimestamps[name] then failTimestamps[name] = now end
        end
    end
    
    if next(unresolved) == nil then return end
    
    -- Get all current frames
    local frames = scrollingFrame:GetChildren()
    
    -- Find frames to reject (check in order)
    for _, frame in ipairs(frames) do
        if not frame:IsA("Frame") then continue end
        
        local sender = stripInvisible(getFrameSender(frame))
        local message = stripInvisible(getFrameMessage(frame))
        local senderLower = (sender:gsub("@",""):lower())
        if not hasAlnum(senderLower) then senderLower = "unknown" end
        local msgHasAlnum = hasAlnum(message)
        
        -- Corrupt frame (unknown sender + no message content)
        if senderLower == "unknown" and not msgHasAlnum then
            if rejectFrameVIM(frame) then
                return  -- Stop after one successful rejection (cooldown active)
            end
            continue
        end
        
        -- Unknown sender but message contains a fail name
        if senderLower == "unknown" then
            local matched = findFailsInText(message, unresolved)
            if matched then
                if rejectFrameVIM(frame) then
                    blockedUsers[matched] = true
                    return
                end
                continue
            end
        end
        
        -- Direct sender match
        if unresolved[senderLower] then
            if rejectFrameVIM(frame) then
                blockedUsers[senderLower] = true
                failTimestamps[senderLower] = nil
                return
            end
            continue
        end
        
        -- Sender text contains fail name
        local matched = findFailsInText(sender, unresolved)
        if matched then
            if rejectFrameVIM(frame) then
                blockedUsers[matched] = true
                failTimestamps[matched] = nil
                return
            end
            continue
        end
    end
end

-- =====================================================
-- Background scanner for corrupt frames (using VIM rejection)
-- =====================================================
task.spawn(function()
    while not KILL do
        local corruptFrames = {}
        for _, frame in ipairs(scrollingFrame:GetChildren()) do
            if frame:IsA("Frame") then
                local sender = stripInvisible(getFrameSender(frame))
                local msg = stripInvisible(getFrameMessage(frame))
                local sLower = sender:gsub("@",""):lower()
                if not hasAlnum(sLower) then sLower = "unknown" end
                if sLower == "unknown" and not hasAlnum(msg) then
                    table.insert(corruptFrames, frame)
                end
            end
        end
        
        -- Reject corrupt frames one at a time
        if #corruptFrames > 0 then
            rejectFrameVIM(corruptFrames[1])
        end
        
        task.wait(0.5)
    end
end)

-- =====================================================
-- Main fail processor loop (runs every 0.5s)
-- =====================================================
task.spawn(function()
    while not KILL do
        processFailsVIM()
        task.wait(0.5)
    end
end)

print("[INIT] VIM rejection method loaded with 5s cooldown ✅")
