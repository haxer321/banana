                    task.wait(0.5)
                    local currentFrames = {}
                    for _, v in ipairs(scrollingFrame:GetChildren()) do
                        if v:IsA("Frame") then table.insert(currentFrames, v) end
                    end
                    if #currentFrames > 4 then
                        print("[GATE] Overflow during guard! Rejecting...")
                        currentAction = "Gate: rejecting overflow in guard"
                        forceReject(currentFrames[math.random(1, #currentFrames)].Name)
                        currentAction = "Gate: 60s overflow guard active"
                    end
                end
                -- after 60 seconds with no overflow (or cleaned), exit
                break
            end
        end
    end

