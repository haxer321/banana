-- CONFIG & STATE
local TARGET      = 0
local FAILS       = {}
local DUPE_FLAG   = false
local CHECK_FLAG  = true
local PACKAGE_GEMS = 10000000
local TELEPORT    = CFrame.new(-460, 244, -67)

-- Roblox elements
